    .prediksi {
        width: 100%;
        max-width: 768px;
        margin: auto;
        margin-bottom: 10px;
    }

    .prediksi p {
        font-size: 12px;
        color: rgb(0, 0, 0, 0.7);
    }

    .quotes2 {
        width: 80%;
        margin: 10px auto;
        padding: 20px 10px;
        font-family: 'Arimo', sans-serif;
        font-size: 14px;
        line-height: 1.5;
    }

    .footer {
        padding: 20px 0;
    }

    .boxBanner {
        margin: 10px auto;
        max-width: 300px;
        width: 100%;
        text-align: center;
    }

    .boxBanner img {
        width: 100%;
    }

    .footer li {
        margin-top: 10px;
    }


    /* ++++++++++++++++++++++++++++++ */

    .card-container {
        width: 100%;
        padding: 10px;
        margin: auto;
        cursor: default;
    }

    .blog-view {
        background-color: #FFF;
        border: 1px solid #555;
        box-shadow: 0 0 2px #333;
        margin: 0 0 10px;
        padding: 10px;
        -ms-word-wrap: break-word;
        word-wrap: break-word;
        border-top: 6px solid #e5b020;
    }

    .entry-title {
        line-height: 1;
        font-size: 1.375rem;
        font-weight: inherit;
    }

    .entry-byline {
        font-size: 14px;
        line-height: 1.6;
    }

    .entry-byline i {
        color: #e4b01f;
    }

    .entry-author,
    .entry-date,
    .entry-categories,
    .entry-comment-info {
        float: left;
        margin-right: 20px;
    }

    .blog-view .entry-content {
        padding-top: 4px;
        padding-bottom: 4px;
        font-family: Arimo, Sans-serif;
        font-size: 14px;
        font-size: .875rem;
        line-height: 1.55;
    }

    .entry-thumbnail {
        float: left;
        padding-right: 8px;
    }

    .entry-excerpt p {
        margin: 0 0 4px;
    }

    .entry-footer {
        clear: both;
    }

    .continue-reading {
        background: #EEE;
        background: -moz-linear-gradient(top, #FBFBFB 0%, #E5E5E5 100%);
        background: -webkit-linear-gradient(top, #FBFBFB 0%, #E5E5E5 100%);
        background: linear-gradient(to bottom, #FBFBFB 0%, #E5E5E5 100%);
        float: right;
        padding: 2px 10px;
        color: #555;
        border: 1px solid #CCC;
        border-radius: 4px;
    }

    .cf:before,
    .cf:after {
        clear: both;
        content: "";
        display: table;
    }

    img[class*="align"],
    img[class*="wp-image-"],
    img[class*="attachment-"],
    .entry-content img,
    .comment-content img {
        height: auto;
        max-width: 100%;
    }

    .card-container a {
        text-decoration: none;
        color: black;
    }

    .card-container a:hover {
        color: blue;
    }

    /* Start Pagination */
    .pagination {
        padding: 4px 0;
        margin-bottom: 10px;
    }

    .link-prev {
        float: left;
    }

    .link-next {
        float: right;
    }

    .link-prev a,
    .link-next a {
        background-color: #FFF;
        display: inline-block;
        padding: 2px 8px;
        border: 1px solid #555;
        box-shadow: 0 0 2px #333;
        color: #333;
    }

    /* End Pagination */
}

@media screen and (max-width: 480px) {
    .entry-thumbnail {
        margin-bottom: 4px;
    }

    .entry-excerpt,
    .entry-thumbnail {
        clear: both;
        padding-right: 0;
    }
}

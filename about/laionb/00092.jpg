[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]},{"story_id":9012415,"section":"olympics","headline":"Paris Olympics 2024 Closing Ceremony Highlights: Thomas Bach Declares Games Closed With French 'Records' Performance","created_at":"2024-08-11 22:06:59","updated_at":"2024-08-12 04:27:17","weburl":"https://www.news18.com/olympics/paris-olympics-2024-closing-ceremony-live-updates-india-medals-tally-manu-bhaker-pr-sreejesh-next-olympics-2028-los-angeles-liveblog-9012415.html","weburl_r":"/olympics/paris-olympics-2024-closing-ceremony-live-updates-india-medals-tally-manu-bhaker-pr-sreejesh-next-olympics-2028-los-angeles-liveblog-9012415.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/copy-of-sports-76-2024-08-6ee4f74992e0e3e9917757096b45bf4e-3x2.jpg","caption":"IOC President Thomas Bach, right, hands over an Olympic flag to Los Angeles Mayor Karen Bass, left, during the 2024 Summer Olympics closing ceremony at the Stade de France, Sunday, Aug. 11, 2024, in Saint-Denis, France. (AP Photo/Kin Cheung)\n\n\n","alt":"IOC President Thomas Bach, right, hands over an Olympic flag to Los Angeles Mayor Karen Bass, left, during the 2024 Summer Olympics closing ceremony at the Stade de France, Sunday, Aug. 11, 2024, in Saint-Denis, France. (AP Photo/Kin Cheung)"},"intro":"Paris Olympics 2024 Closing Ceremony Highlights: Get all the highlights from the closing ceremony of the 33rd edition of the Summer Games.\r\n","display_headline":"Paris Olympics 2024 Closing Ceremony Highlights: Thomas Bach Declares Games Closed With French 'Records' Performance","post_type":"text","categories":[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]},{"story_id":9012343,"section":"olympics","headline":"Manu Bhaker's Double Bronze Headlines India's 6-Medal Success in Paris, 6 Fall Just Short","created_at":"2024-08-11 16:35:43","updated_at":"2024-08-11 16:36:57","weburl":"https://www.news18.com/olympics/manu-bhakers-double-bronze-headlines-indias-6-medal-success-in-paris-6-fall-just-short-9012343.html","weburl_r":"/olympics/manu-bhakers-double-bronze-headlines-indias-6-medal-success-in-paris-6-fall-just-short-9012343.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/paris-olympics-2024_india-medal-2024-08-0c18a2103a1c540862049fdfc8d7a48d-3x2.jpg","caption":"India's medal winners at Paris Olympics 2024 (AP)","alt":"India's medal winners at Paris Olympics 2024"},"intro":"Indian athletes toiled hard during the 2024 Paris Olympics to return a medal haul of one silver and five bronze.","display_headline":"Manu Bhaker's Double Bronze Headlines India's 6-Medal Success in Paris, 6 Fall Just Short","post_type":"text","categories":[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]},{"story_id":9012511,"section":"olympics","headline":"USA Pips China in Final Medal Count as Paris 2024 Olympics Looks to Close on a High Note","created_at":"2024-08-11 21:49:41","updated_at":"2024-08-11 21:49:41","weburl":"https://www.news18.com/olympics/usa-pips-china-in-final-medal-count-as-paris-2024-olympics-looks-to-close-on-a-high-note-9012511.html","weburl_r":"/olympics/usa-pips-china-in-final-medal-count-as-paris-2024-olympics-looks-to-close-on-a-high-note-9012511.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/team-usa-mens-basketball-afp-feature-2024-08-20957c9e5dc874d360c4b3cbacdebf42-3x2.png","caption":"USA's Men's and Women's Basketball team pipped the French side to take home the respective gold medals. (Image: AFP)","alt":"USA's Men's and Women's Basketball team pipped the French side to take home the respective gold medals. (Image: AFP)"},"intro":"The United States pipped China for the top spot in the battle of medals as Paris prepared to bring the curtain down on one of the most successful Olympic Games in history.","display_headline":"USA Pips China in Final Medal Count as Paris 2024 Olympics Looks to Close on a High Note","post_type":"text","categories":[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]},{"story_id":9012213,"section":"olympics","headline":"Paris Olympics 2024: Complete Result of Every Indian Athlete Who Participated in 33rd Summer Games","created_at":"2024-08-11 16:23:40","updated_at":"2024-08-11 22:57:00","weburl":"https://www.news18.com/olympics/paris-olympics-2024-complete-result-of-every-indian-athlete-who-participated-in-the-33rd-summer-games-9012213.html","weburl_r":"/olympics/paris-olympics-2024-complete-result-of-every-indian-athlete-who-participated-in-the-33rd-summer-games-9012213.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/india-2024-08-adf6a320c88cd0d7152e46aca76915bb-3x2.jpg","caption":"India at Paris Olympics 2024. (Picture Credit: AP)","alt":"India at Paris Olympics 2024"},"intro":"Here is a look at the performances of all the athletes who represented India at the Paris Olympics 2024.","display_headline":"Paris Olympics 2024: Complete Result of Every Indian Athlete Who Participated in 33rd Summer Games","post_type":"text","categories":[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]},{"story_id":9012488,"section":"olympics","headline":"Paris Olympics 2024: India Finish 71st as United States Top Final Medals Table","created_at":"2024-08-11 21:11:00","updated_at":"2024-08-13 21:18:56","weburl":"https://www.news18.com/olympics/paris-olympics-2024-india-ranked-71st-as-united-states-top-final-medals-table-9012488.html","weburl_r":"/olympics/paris-olympics-2024-india-ranked-71st-as-united-states-top-final-medals-table-9012488.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/paris-olympics-2024-final-medals-table-2024-08-8707e8015b1e88d9d4983bf23a188fce-3x2.jpg","caption":"India finished 71st in the Paris Olympics 2024 final medals table (AP and REUTERS)","alt":"India finished 71st in the Paris Olympics 2024 final medals table"},"intro":"India finished 71st with one silver and five bronze as The United States topped the medals table at end of 2024 Paris Olympics.","display_headline":"Paris Olympics 2024: India Finish 71st as United States Top Final Medals Table","post_type":"text","liveblog_api_url":{},"categories":[{"parent":13,"name":"Olympics","id":322563,"permalink":1,"slug":"olympics"},{"parent":0,"name":"Sports","id":13,"permalink":0,"slug":"sports"}]},{"story_id":9012447,"section":"olympics","headline":"Paris 2024: French Police Evacuate Area Around Eiffel Tower After Man Climbs Landmark Ahead of Closing Ceremony","created_at":"2024-08-11 20:12:57","updated_at":"2024-08-11 20:12:57","weburl":"https://www.news18.com/olympics/paris-2024-french-police-evacuate-area-around-eiffel-tower-after-man-climbs-landmark-ahead-of-closing-ceremony-9012447.html","weburl_r":"/olympics/paris-2024-french-police-evacuate-area-around-eiffel-tower-after-man-climbs-landmark-ahead-of-closing-ceremony-9012447.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2024/08/copy-of-sports-70-2024-08-515e27707b830804d01dcb07e554c639-3x2.jpg","caption":"Police evacuate the area around the Eiffel Tower after a man was seen climbing the historic landmark, during the 2024 Summer Olympics, Sunday, Aug. 11, 2024, in Paris France. (AP Photo/Aijaz Rahi)\n\n\n","alt":"Police evacuate the area around the Eiffel Tower after a man was seen climbing the historic landmark, during the 2024 Summer Olympics, Sunday, Aug. 11, 2024, in Paris France. (AP Photo/Aijaz Rahi)"},"intro":"The shirtless man was seen scaling the 330-meter tall tower in the afternoon. He was spotted just above the Olympic rings adorning the second section of the monument, just above the first viewing deck.","display_headline":"Paris 2024: French Police Evacuate Area Around Eiffel Tower After Man Climbs Landmark Ahead of Closing Ceremony","post_type":"text","categories":[{"id":322563,"name":"Olympics","slug":"olympics","parent":13,"permalink":1},{"id":13,"name":"Sports","slug":"sports","parent":0,"permalink":0}]}],"podcastsData":[{"article_details":{"agency":"News18.com","agency_full":{"hindi":"News18.com","english":"news18.com","id":"","slug":"news18-com"},"author_byline":[],"categories":[{"id":1779373,"name":"News18 Daily Digest","slug":"news18-daily-digest","parent":0,"permalink":1}],"created_at":"2026-03-04 07:11:17","display_headline":"News18 Daily Digest, March 4: Iran Succession Buzz | What The US-Iran-Israel War Means For India","dm_video_id":"","ff_source":"","liveblog_switcher":0,"gallery":[],"gallery_count":0,"headline":"News18 Daily Digest, March 4: Iran Succession Buzz | What The US-Iran-Israel War Means For India","images":{"url":"https://images.news18.com/ibnlive/uploads/2026/03/DAILY_DIGEST_04_MAR-2026-03-456cc9c15317a83c2bc8993268a9fbf8.png","caption":"","alt":""},"images_all_sizes":{"mime_type":"image/jpeg","url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo.jpg","caption":"News18","sizes":{"16x9":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x900.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x1200.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1200x800.jpg"}}},"intro":"\u003cp\u003eIn today's \u003cem\u003eNews18 Daily Digest\u003c/em\u003e: As the conflict involving the United States, Israel and Iran enters a critical phase, global focus shifts to what a prolonged war could mean for West Asia and beyond. With Iran’s Supreme Leader reportedly killed earlier in the conflict, succession discussions are intensifying in Tehran, while Israel signals expanded operations and Washington warns of further consequences. We also look at what this means for India — from the safety of over 1 crore Indians in the Gulf and evacuation discussions for students in Iran, to oil supply concerns and the strategic importance of the Strait of Hormuz. Plus, the economic costs of war, aviation disruptions, and the political debate back home. Tune in for key developments and in-depth updates from India and across the globe.\u003c/p\u003e","liveblog_api_url":{"status":0,"title":"","blog_url":""},"has_video":false,"embedded_widget":[{"widget_type":"coral_comment","widget_value":false}],"post_type":"podcast","gif_n18_images":{"url":null,"alt":null},"liveblog_start_time":null,"liveblog_end_time":null,"story_id":9941443,"timetoread":"1-MIN READ","updated_at":"2026-03-04 07:11:17","weburl":"https://www.news18.com/podcast/news18-daily-digest/news18-daily-digest-march-4-iran-succession-buzz-what-the-us-iran-israel-war-means-for-india-9941443.html","weburl_r":"/podcast/news18-daily-digest/news18-daily-digest-march-4-iran-succession-buzz-what-the-us-iran-israel-war-means-for-india-9941443.html","youtube_thumbnail":"","youtubeid":"","app_light_body":"[]","app_headline":"","app_only":0,"app_first":0,"app_intro":"","premium_content":0},"article_id":9941443,"auto_refresh":0,"id":"podcast_NA_9941443","ranking":1,"relatedstories_checkbox":0,"status":1,"section":"podcast","subsection":"NA","created_at":"2026-03-04 07:11:40","updated_at":null},{"article_details":{"agency":"News18.com","agency_full":{"hindi":"News18.com","english":"news18.com","id":"","slug":"news18-com"},"author_byline":[{"id":"14602","english_name":"Nitya Thirumalai","nicename":"nitya_thirumalai","blog_title":"","author_bio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","fullbio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","avtar":"https://images.news18.com/ibnlive/uploads/2023/11/nitya-thirumalai1-2023-11-1485d63639dd62fd11e649baeff9a269.jpg","author_email":"nitya.thirumalai@network18online.com","website":"https://www.news18.com","twitter":"https://twitter.com/nitsthirumalai","facebook":"","instagram":"","youtube":"","linkedin":"","designation":"News Editor","author_type":"","author_location":"","status":"","company":""}],"categories":[{"id":1778581,"name":"News18 Straight Talk","slug":"news18-straight-talk","parent":0,"permalink":1}],"created_at":"2025-10-31 08:37:00","display_headline":"Sir Creek To Karachi: India’s Trishul Warning","dm_video_id":"","ff_source":"","liveblog_switcher":0,"gallery":[],"gallery_count":0,"headline":"Sir Creek To Karachi: India’s Trishul Warning","images":{"url":"https://images.news18.com/ibnlive/uploads/2025/10/Straight-Talk-Exercise-Trishul-2025-10-2b337369e1f59e56e4c22d97f42f5509.png","caption":"","alt":""},"images_all_sizes":{"mime_type":"image/jpeg","url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo.jpg","caption":"News18","sizes":{"16x9":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x900.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x1200.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1200x800.jpg"}}},"intro":"\u003cp\u003eIndia’s Exercise Trishul isn’t a routine drill — it’s a calibrated show of power stretching from Sir Creek to Karachi. As 20,000 troops, Rafales, and warships move in sync, India sends its clearest message yet to Pakistan: restraint is over. Tune in as Sanbeer Ranhotra breaks down how Trishul redefines deterrence and redraws the rules of engagement in South Asia.\u003c/p\u003e","liveblog_api_url":{"status":0,"title":"","blog_url":""},"has_video":false,"embedded_widget":[{"widget_type":"coral_comment","widget_value":false}],"post_type":"podcast","gif_n18_images":{"url":null,"alt":null},"liveblog_start_time":null,"liveblog_end_time":null,"story_id":9670737,"timetoread":"1-MIN READ","updated_at":"2025-10-31 08:37:00","weburl":"https://www.news18.com/podcast/news18-straight-talk/sir-creek-to-karachi-india-s-trishul-warning-9670737.html","weburl_r":"/podcast/news18-straight-talk/sir-creek-to-karachi-india-s-trishul-warning-9670737.html","youtube_thumbnail":"","youtubeid":"","app_light_body":"[]","app_headline":"","app_only":0,"app_first":0,"app_intro":"","premium_content":0},"article_id":9670737,"auto_refresh":0,"id":"podcast_NA_9670737","ranking":2,"relatedstories_checkbox":0,"status":1,"section":"podcast","subsection":"NA","created_at":"2026-03-04 07:11:40","updated_at":null},{"article_details":{"agency":"News18.com","agency_full":{"hindi":"News18.com","english":"news18.com","id":"","slug":"news18-com"},"author_byline":[{"id":"14602","english_name":"Nitya Thirumalai","nicename":"nitya_thirumalai","blog_title":"","author_bio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","fullbio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","avtar":"https://images.news18.com/ibnlive/uploads/2023/11/nitya-thirumalai1-2023-11-1485d63639dd62fd11e649baeff9a269.jpg","author_email":"nitya.thirumalai@network18online.com","website":"https://www.news18.com","twitter":"https://twitter.com/nitsthirumalai","facebook":"","instagram":"","youtube":"","linkedin":"","designation":"News Editor","author_type":"","author_location":"","status":"","company":""}],"categories":[{"id":1778581,"name":"News18 Straight Talk","slug":"news18-straight-talk","parent":0,"permalink":1}],"created_at":"2025-10-22 12:32:40","display_headline":"Pakistan Unravels — The Terror State Consumed By Its Own Fires","dm_video_id":"","ff_source":"","liveblog_switcher":0,"gallery":[],"gallery_count":0,"headline":"Pakistan Unravels — The Terror State Consumed By Its Own Fires","images":{"url":"https://images.news18.com/ibnlive/uploads/2025/10/Straight-Talk-Vol-47-2025-10-0202a34bcda21887959691964c3e0ca5.png","caption":"","alt":""},"images_all_sizes":{"mime_type":"image/jpeg","url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo.jpg","caption":"News18","sizes":{"16x9":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x900.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x1200.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1200x800.jpg"}}},"intro":"\u003cp\u003ePakistan faces its gravest crisis yet — a border war with Afghanistan, rising insurgencies in Balochistan and Punjab province, economic collapse, and military overreach. Once the exporter of terror, Islamabad now bleeds from within. Tune in as Sanbeer Ranhotra unpacks Pakistan’s self-inflicted unraveling and its dangerous implications for the region in this episode of \u003cem\u003eStraight Talk\u003c/em\u003e.\u003c/p\u003e","liveblog_api_url":{"status":0,"title":"","blog_url":""},"has_video":false,"embedded_widget":[{"widget_type":"coral_comment","widget_value":false}],"post_type":"podcast","gif_n18_images":{"url":null,"alt":null},"liveblog_start_time":null,"liveblog_end_time":null,"story_id":9651383,"timetoread":"1-MIN READ","updated_at":"2025-10-22 12:32:40","weburl":"https://www.news18.com/podcast/news18-straight-talk/pakistan-unravels-the-terror-state-consumed-by-its-own-fires-9651383.html","weburl_r":"/podcast/news18-straight-talk/pakistan-unravels-the-terror-state-consumed-by-its-own-fires-9651383.html","youtube_thumbnail":"","youtubeid":"","app_light_body":"[]","app_headline":"","app_only":0,"app_first":0,"app_intro":"","premium_content":0},"article_id":9651383,"auto_refresh":0,"id":"podcast_NA_9651383","ranking":3,"relatedstories_checkbox":0,"status":1,"section":"podcast","subsection":"NA","created_at":"2026-03-04 07:11:40","updated_at":null},{"article_details":{"agency":"News18.com","agency_full":{"hindi":"News18.com","english":"news18.com","id":"","slug":"news18-com"},"author_byline":[{"id":"14602","english_name":"Nitya Thirumalai","nicename":"nitya_thirumalai","blog_title":"","author_bio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","fullbio":"Nitya Thirumalai, News Editor at News18.com, writes on Indian and global politics as well as Formula 1. She was Google News Initiative-Columbia Journalism School Fellow in the inaugural Newsroom Leadership Programme in 2019. Follow her @NitsThirumalai","avtar":"https://images.news18.com/ibnlive/uploads/2023/11/nitya-thirumalai1-2023-11-1485d63639dd62fd11e649baeff9a269.jpg","author_email":"nitya.thirumalai@network18online.com","website":"https://www.news18.com","twitter":"https://twitter.com/nitsthirumalai","facebook":"","instagram":"","youtube":"","linkedin":"","designation":"News Editor","author_type":"","author_location":"","status":"","company":""}],"categories":[{"id":1778581,"name":"News18 Straight Talk","slug":"news18-straight-talk","parent":0,"permalink":1}],"created_at":"2025-08-27 13:57:03","display_headline":"From Fighters To Engines: Why France Is The Only Logical Partner For India","dm_video_id":"","ff_source":"","liveblog_switcher":0,"gallery":[],"gallery_count":0,"headline":"From Fighters To Engines: Why France Is The Only Logical Partner For India","images":{"url":"https://images.news18.com/ibnlive/uploads/2025/08/Straight-Talk-Vol-45-2025-08-1d8a8bef8172129438621c103baecc24.png","caption":"","alt":""},"images_all_sizes":{"mime_type":"image/jpeg","url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo.jpg","caption":"News18","sizes":{"16x9":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x900.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1600x1200.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2021/07/1627283897_news18_logo-1200x800.jpg"}}},"intro":"\u003cp\u003eFrance's exceptional willingness to share crown jewel technology is a recognition of India's evolution from aid recipient to strategic partner in global power equations. As India approaches its 2047 development goals, such partnerships will prove crucial in achieving the technological sovereignty that underpins genuine strategic autonomy.\u003c/p\u003e","liveblog_api_url":{"status":0,"title":"","blog_url":""},"has_video":false,"embedded_widget":[{"widget_type":"coral_comment","widget_value":false}],"post_type":"podcast","gif_n18_images":{"url":null,"alt":null},"liveblog_start_time":null,"liveblog_end_time":null,"story_id":9531415,"timetoread":"1-MIN READ","updated_at":"2025-08-27 13:57:03","weburl":"https://www.news18.com/podcast/news18-straight-talk/from-fighters-to-engines-why-france-is-the-only-logical-partner-for-india-9531415.html","weburl_r":"/podcast/news18-straight-talk/from-fighters-to-engines-why-france-is-the-only-logical-partner-for-india-9531415.html","youtube_thumbnail":"","youtubeid":"","app_light_body":"[]","app_headline":"","app_only":0,"app_first":0,"app_intro":"","premium_content":0},"article_id":9531415,"auto_refresh":0,"
d7-16x9.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2026/02/Rahul-Stalin-edtt-2026-02-ea3920fec75216d63d6cdcffb3e444d7-4x3.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2026/02/Rahul-Stalin-edtt-2026-02-ea3920fec75216d63d6cdcffb3e444d7-3x2.jpg"}}},"app_first":0,"has_video":false}],"sectionName":"Politics"},{"sectionData":[{"story_id":9896801,"section":"opinion_news","headline":"Opinion | Restoring Vande Mataram, Rejecting The Politics Of 1937","created_at":"2026-02-11 21:19:01","updated_at":"2026-02-11 21:19:01","weburl":"https://www.news18.com/opinion/opinion-restoring-vande-mataram-rejecting-the-politics-of-1937-9896801.html","weburl_r":"/opinion/opinion-restoring-vande-mataram-rejecting-the-politics-of-1937-9896801.html","images":{"url":"https://images.news18.com/ibnlive/uploads/2026/02/Untitled-design-2026-02-05T143548.817-2026-02-c0de428e014ee6f0dc8051481e0b6e9d-3x2.jpg","caption":"From a unifying symbol, Vande Mataram was recast by Jinnah as a sectarian test of loyalty, used to question Muslim commitment to the idea of Pakistan. (Image: X)","alt":"This Is Mumbai's First Luxury Hotel, Where Mohammad Ali Jinnah Played Pool \u0026 India’s First Film Screening Was Hosted"},"intro":"Since 1937, when Muhammad Ali Jinnah took offence, Indians have only ever sung the first two stanzas of their National Song","display_headline":"Opinion | Restoring Vande Mataram, Rejecting The Politics Of 1937","post_type":"text","liveblog_api_url":{"status":0,"title":"","blog_url":""},"categories":[{"id":502231,"name":"Opinion","slug":"opinion","parent":0,"permalink":1}],"images_all_sizes":{"mime_type":"image/jpeg","url":"https://images.news18.com/ibnlive/uploads/2026/02/Untitled-design-2026-02-05T143548.817-2026-02-c0de428e014ee6f0dc8051481e0b6e9d.jpg","caption":"From a unifying symbol, Vande Mataram was recast by Jinnah as a sectarian test of loyalty, used to question Muslim commitment to the idea of Pakistan. (Image: X)","sizes":{"16x9":{"url":"htt
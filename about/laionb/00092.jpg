2885e558de83338d98ed06ca94d0-1200x675.jpg"},"4x3":{"url":"https://images.news18.com/ibnlive/uploads/2026/02/image-2026-02-3b8b2885e558de83338d98ed06ca94d0-1200x900.jpg"},"3x2":{"url":"https://images.news18.com/ibnlive/uploads/2026/02/image-2026-02-3b8b2885e558de83338d98ed06ca94d0-1200x800.jpg"}}},"intro":"Gaurav Singh, 28, was booked for allegedly abusing and attempting to assault police at Santacruz station on March 1. He threatened to kill his girlfriend after a fight.","liveblog_api_url":{"status":0,"title":"","blog_url":""},"has_video":false,"meta_description":"Gaurav Singh was booked for allegedly abusing and attempting to assault police after threatening his girlfriend, Tanvi Jain, at a restaurant in Khar West.","post_type":"text","story_id":9942517,"updated_at":"2026-03-04 20:27:13","weburl":"https://www.news18.com/cities/mumbai-news/28-year-old-man-booked-for-abusing-girlfriend-assaulting-cop-in-mumbai-ws-l-9942517.html","weburl_r":"/cities/mumbai-news/28-year-old-man-booked-for-abusing-girlfriend-assaulting-cop-in-mumbai-ws-l-9942517.html","app_first":0},{"section":["Ahmedabad","Bhopal","Cities","Dehradun","Ghaziabad","Jaipur","Lucknow","Mumbai","New Delhi","Noida"],"author_byline":[{"id":"16783","english_name":"Diksha Modi","slug":"diksha-modi","nicename":"","blog_title":"","author_email":"dikshamodi.12@gmail.com","designation":"","author_bio":"","avtar":"","website":"","twitter":"","facebook":"","instagram":"","fullbio":"","author_type":"digital","author_location":"","author_blogname":"","company":"","youtube":"","linkedin":"","status":"1"}],"categories":[{"id":1779214,"name":"New Delhi","slug":"new-delhi-news","parent":1779213,"permalink":1},{"id":1779678,"name":"Ahmedabad","slug":"ahmedabad","parent":1779213,"permalink":0},{"id":1779700,"name":"Bhopal","slug":"bhopal","parent":1779213,"permalink":0},{"id":1779213,"name":"Cities","slug":"cities","parent":0,"permalink":0},{"id":1779682,"name":"Dehradun","slug":"dehradun","parent":1779213,"permalink":0},{"
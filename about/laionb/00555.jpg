<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PantherMedia - Important Notice</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background-color: #ffffff;
            color: #000000;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background-color: #000000;
            color: #ffffff;
            padding: 30px 0;
            text-align: center;
            border-bottom: 3px solid #333333;
        }

        header h1 {
            font-size: 2.5em;
            font-weight: 700;
            letter-spacing: 2px;
        }

        .main-content {
            background-color: #ffffff;
            padding: 60px 20px;
            text-align: center;
        }

        .notice-box {
            background-color: #f5f5f5;
            border: 2px solid #000000;
            padding: 40px;
            margin: 40px auto;
            max-width: 800px;
        }

        .notice-box h2 {
            font-size: 2em;
            margin-bottom: 20px;
            color: #000000;
        }

        .notice-box p {
            font-size: 1.1em;
            margin-bottom: 15px;
            color: #333333;
        }

        .copyright-section {
            background-color: #000000;
            color: #ffffff;
            padding: 50px 20px;
            margin: 40px 0;
        }

        .copyright-section h2 {
            font-size: 2em;
            margin-bottom: 30px;
            text-align: center;
        }

        .info-block {
            background-color: #1a1a1a;
            border-left: 4px solid #ffffff;
            padding: 25px;
            margin: 20px auto;
            max-width: 800px;
            text-align: left;
        }

        .info-block h3 {
            font-size: 1.4em;
            margin-bottom: 15px;
            color: #ffffff;
        }

        .info-block p {
            margin-bottom: 12px;
            color: #cccccc;
            line-height: 1.8;
        }

        .info-block ul {
            margin-left: 20px;
            margin-top: 10px;
            color: #cccccc;
        }

        .info-block li {
            margin-bottom: 8px;
        }

        .search-box {
            background-color: #ffffff;
            border: 2px solid #000000;
            padding: 30px;
            margin: 30px auto;
            max-width: 600px;
        }

        .search-box h3 {
            font-size: 1.5em;
            margin-bottom: 20px;
            color: #000000;
        }

        .search-input {
            width: 100%;
            padding: 15px;
            font-size: 1.1em;
            border: 2px solid #333333;
            margin-bottom: 15px;
        }

        .search-button {
            background-color: #000000;
            color: #ffffff;
            padding: 15px 40px;
            font-size: 1.1em;
            border: none;
            cursor: pointer;
            transition: background-color 0.3s;
            width: 100%;
        }

        .search-button:hover {
            background-color: #333333;
        }

        .payment-info {
            background-color: #f9f9f9;
            border: 2px solid #000000;
            padding: 25px;
            margin: 20px auto;
            max-width: 800px;
            text-align: left;
        }

        .payment-info strong {
            color: #000000;
            font-size: 1.1em;
        }

        .highlight {
            background-color: #000000;
            color: #ffffff;
            padding: 2px 6px;
            font-weight: bold;
        }

        footer {
            background-color: #000000;
            color: #ffffff;
            text-align: center;
            padding: 30px 20px;
            margin-top: 60px;
        }

        footer p {
            margin: 10px 0;
        }

        a {
            color: #ffffff;
            text-decoration: underline;
        }

        a:hover {
            color: #cccccc;
        }

        .divider {
            height: 2px;
            background-color: #000000;
            margin: 40px auto;
            max-width: 800px;
        }

        @media (max-width: 768px) {
            header h1 {
                font-size: 1.8em;
            }

            .notice-box, .info-block, .search-box, .payment-info {
                padding: 20px;
            }

            .notice-box h2, .copyright-section h2 {
                font-size: 1.5em;
            }
        }
    </style>
</head>
<body>
    <header>
        <div class="container">

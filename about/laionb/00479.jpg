eaf-1fcf-8fc0008f9265" class="accordion_header_title_wrap"><h3 fs-cmssort-field="name" fs-cmsfilter-field="title" data-wf--global-headings--heading-size="small" class="heading w-variant-0b89f5b0-36ad-26da-fe53-ec8c90d04593 u-text-style-h3 u-mb-0 u-max-width-20ch u-child-contain">Economic Justice</h3></div><div fs-accordion-element="arrow" data-w-id="abdf36b6-c7a3-6eaf-1fcf-8fc0008f9267" class="issues_icon_wrap"><div class="card-color-bg_icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" height="100%" viewBox="0 -960 960 960" width="24px" fill="currentcolor"><path d="m560-240-56-58 142-142H160v-80h486L504-662l56-58 240 240-240 240Z"/></svg></div></div></div><div class="g_clickable_wrap"><a target="" href="/programs/economic-justice" class="g_clickable_link w-inline-block"><span class="g_clickable_text u-sr-only"></span></a><button type="button" class="g_clickable_btn"><span class="g_clickable_text u-sr-only"></span></button></div></div></div></div></div></div></div></div><div data-wf--global-section-space--section-space="main" class="g_section_space w-variant-60a7ad7d-02b0-6682-95a5-2218e6fd1490"></div></section><div class="product_news_wrap"><section data-wf--section-products-full-3--styles-theme="dark" class="section w-variant-5bc694f6-f145-b567-c4d2-20a61b735d81"><div data-wf--global-section-space--section-space="main" class="g_section_space w-variant-60a7ad7d-02b0-6682-95a5-2218e6fd1490"></div><div class="u-container u-position-relative u-vflex-left-top u-gap-4"><div class="issues_link_title_wrap u-mb-text u-position-relative"><div class="g_clickable_wrap"><a target="" href="/resources" class="g_clickable_link w-inline-block"><span class="g_clickable_text u-sr-only"></span></a><button type="button" class="g_clickable_btn"><span class="g_clickable_text u-sr-only"></span></button></div><h2 fs-cmssort-field="name" fs-cmsfilter-field="title" data-wf--global-headings--heading-size="medium" class="heading w-variant-6f397166-5769-8472-688d-d383addb3f81 title u-mb-0">Explore our latest work</h2><div class="hide-desk w-variant-5bc694f6-f145-b567-c4d2-20a61b735d81"><div class="card-color-bg_icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" height="100%" viewBox="0 -960 960 960" width="24px" fill="currentcolor"><path d="m560-240-56-58 142-142H160v-80h486L504-662l56-58 240 240-240 240Z"/></svg></div></div><div class="hide-mobile w-variant-5bc694f6-f145-b567-c4d2-20a61b735d81"><div data-wf--btn-link--size="regular" class="link_wrap u-position-relative w-variant-200e938f-8e87-6456-38a6-f42987e7f619"><div class="g_clickable_wrap"><a target="" href="/resources" class="g_clickable_link w-inline-block"><span class="g_clickable_text u-sr-only"></span></a><button type="button" class="g_clickable_btn"><span class="g_clickable_text u-sr-only"></span></button></div><div class="link_layout w-variant-200e938f-8e87-6456-38a6-f42987e7f619"><div class="button_text">See All</div><div class="card-color-bg_icon w-variant-200e938f-8e87-6456-38a6-f42987e7f619 w-embed"><svg xmlns="http://www.w3.org/2000/svg" height="100%" viewBox="0 -960 960 960" fill="currentcolor"><path d="m560-240-56-58 142-142H160v-80h486L504-662l56-58 240 240-240 240Z"/></svg></div></div></div></div></div><div class="product_cards_wrap w-dyn-list"><div role="list" class="product_cards_wrap_grid u-grid-column-3 u-gap-5 w-variant-5bc694f6-f145-b567-c4d2-20a61b735d81 w-dyn-items"><div role="listitem" class="w-dyn-item"><div data-w-id="e4c228d6-7832-7b7e-2f78-7928f82ab935" class="card-product-resources_wrap"><div class="card_content_wrap prod-card-settings"><div class="card_content_tag_wrap u-hflex-between-center white-5"><div class="card-date white-6">February 16, 2026</div></div><h3 fs-cmssort-field="name" fs-cmsfilter-field="title" data-wf--global-headings--heading-size="x-small" class="heading w-variant-ad34cb72-dfdf-bd78-139e-437ff43a6c66 u-line-clamp-3">Bridges Over Troubled Water: Assessing the national bridging landscape of partnerships between health departments and community power-building organizations</h3><p data-wf--global-paragraphs--paragraph-size="small" class="paragraph excerpt u-line-clamp-3">This report is an assessment of the national landscape of bridging partnerships – collaborations between governmental public health departments and community power-building organizations. </p></div><div class="card_image_wrap prod-card-settings"><img alt="Bridges Over Troubled Water: Assessing the national bridging landscape of partnerships between health departments and community power-building organizations" src="https://cdn.prod.website-files.com/67cafbff6880dabe1f2342b0/698b6a7d23cafc78412c4e67_Kresge%20Article%20-%20HIP%20PPH.png" loading="lazy" class="card_image"/><div class="card-arrow-wrap"><img loading="lazy" src="https://cdn.prod.website-files.com/67cafbe119c354c4ed129501/67f01db95169c72835d7ff8c_hip-arrow-card-hover.svg" alt=""/></div></div><div class="g_clickable_wrap"><a target="" href="/resources/bridges-over-troubled-water-assessing-the-national-bridging-landscape-of-partnerships-between-health-departments-and-community-power-building-organizations" class="g_clickable_link w-inline-block"><span class="g_clickable_text u-sr-only"></span></a><button type="button" class="g_clickable_btn"><span class="g_clickable_text u-sr-only"></span></button></div></div></div><div role="listitem" class="w-dyn-item"><div data-w-id="e4c228d6-7832-7b7e-2f78-7928f82ab935" class="card-product-resources_wrap"><div class="card_content_wrap prod-card-settings"><div class="card_content_tag_wrap u-hflex-between-center white-5"><div class="card-date white-6">January 22, 2026</div></div><h3 fs-cmssort-field="name" fs-cmsfilter-field="title" data-wf--global-headings--heading-size="x-small" class="heading w-variant-ad34cb72-dfdf-bd78-139e-437ff43a6c66 u-line-clamp-3">California Renter Health Survey: Preliminary Findings</h3><p data-wf--global-paragraphs--paragraph-size="small" class="paragraph excerpt u-line-clamp-3">This brief presents early findings from a new statewide survey examining how California’s housing conditions, and rising rents in particular, are shaping renters’ health and the health workforce.</p></div><div class="card_image_wrap prod-card-settings"><img alt="California Renter Health Survey: Preliminary Findings" src="https://cdn.prod.website-files.com/67cafbff6880dabe1f2342b0/69728da1fd731c9de713c7e5_CA%20renter%20health%20survey%20(1).jpg" loading="lazy" class="card_image"/><div class="card-arrow-wrap"><img loading="lazy" src="https://cdn.prod.website-files.com/67cafbe119c354c4ed129501/67f01db95169c72835d7ff8c_hip-arrow-card-hover.svg" alt=""/></div></div><div class="g_clickable_wrap"><a target="" href="/resources/california-renter-health-survey-preliminary-findings" class="g_clickable_link w-inline-block"><span class="g_clickable_text u-sr-only"></span></a><button type="button" class="g_clickable_btn"><span class="g_clickable_text u-sr-only"></span></button></div></div></div><div role="listitem" class="w-dyn-item"><div data-w-id="e4c228d6-7832-7b7e-2f78-7928f82ab935" class="card-product-resources_wrap"><div class="card_content_wrap prod-card-settings"><div class="card_content_tag_wrap u-hflex-between-center white-5"><div class="card-date white-6">December 15, 2025</div></div><h3 fs-cmssort-field="name" fs-cmsfilter-field="title" data-wf--global-headings--heading-size="x-small" class="heading w-variant-ad34cb72-dfdf-bd78-139e-437ff43a6c66 u-line-clamp-3">The Health Benefits of Rent Control: A Policy Brief for Public Health Practitioners  </h3><p data-wf--global-paragraphs--paragraph-size="small" class="paragraph excerpt u-line-clamp-3">This paper presents the evidence concerning rent control and health and discusses the roles that public health practitioners and organizations can play in advancing rent control. </p></div><div class="card_image_wrap prod-card-settings"><img alt="The Health Benefits of Rent Control: A Policy Brief for Public Health Practitioners  " src="https://cdn.prod.website-file
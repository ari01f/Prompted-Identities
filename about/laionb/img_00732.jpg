",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly under your own arrangements and stay for 2 nights at Jose Antonio Lima or similar.\u003c/p\u003e\u003cp\u003e\u003cem\u003eOur travel specialists will be delighted to assist with flight arrangements if required.\u003c/em\u003e\u003c/p\u003e\",\"dayLandOnly\":true,\"dayTitle\":\"Fly to Lima\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNYGw\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":4698,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Lima\",\"cityTo\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"4lXD1QprlKmqniOHajNYSn\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNYee\",\"accommodation\":{\"_ref\":\"accommodation-33374\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23768]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNYWk\",\"city\":\"Lima\",\"cityID\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":2,\"dayDescription\":\"\u003cp\u003eMorning city tour of Lima, one of the major cities in the Spanish conquest of the Americas. Perhaps add an optional visit to the Larco museum, or a culinary tour with a visit to a local market and cooking lesson.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Lima\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNYah\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":4698,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Lima\",\"cityTo\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"4lXD1QprlKmqniOHajNYib\",\"day\":2.1,\"dayTitle\":\"Transfer: Lima to Sacred Valley\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNYmY\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":3247,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Sacred Valley\",\"cityTo\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Flight\"}]},{\"_key\":\"4lXD1QprlKmqniOHajNYqV\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNYuS\",\"accommodation\":{\"_ref\":\"accommodation-33232\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23796]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNYyP\",\"city\":\"Cusco\",\"cityID\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":3,\"dayDescription\":\"\u003cp\u003eMorning flight to Cuzco, set in the Andes mountains. Transfer to the Sacred Valley of the Incas, visiting the indigenous market at Pisac en route. Stay 2 nights at Andean Wings.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Fly to Cuzco • Sacred Valley\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZ2M\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":3247,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Sacred Valley\",\"cityTo\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Flight\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"4lXD1QprlKmqniOHajNZ6J\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNZIA\",\"accommodation\":{\"_ref\":\"accommodation-33232\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23796]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNZAG\",\"city\":\"Sacred Valley\",\"cityID\":{\"_ref\":\"geotree_district_252911\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":4,\"dayDescription\":\"\u003cp\u003eDay at leisure. Optional tours include a visit to the Inca fortress of Ollantaytambo, an excursion to see the Maras salt pans and Moray, or a trip to see a local community.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Sacred Valley / Ollantaytambo\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZED\",\"cityFrom\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3247,\"cityIDTo\":3247,\"cityNameFrom\":\"Sacred Valley\",\"cityNameTo\":\"Sacred Valley\",\"cityTo\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"4lXD1QprlKmqniOHajNZM7\",\"day\":4.1,\"dayTitle\":\"Transfer: Sacred Valley to Machu Picchu\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZQ4\",\"cityFrom\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3247,\"cityIDTo\":2990,\"cityNameFrom\":\"Sacred Valley\",\"cityNameTo\":\"Machu Picchu\",\"cityTo\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}]},{\"_key\":\"4lXD1QprlKmqniOHajNZU1\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNZfs\",\"accommodation\":{\"_ref\":\"accommodation-37554\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24589]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNZXy\",\"city\":\"Machu Picchu\",\"cityID\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":5,\"dayDescription\":\"\u003cp\u003eTransfer to Ollanta station and take the train to Machu Picchu, one of the world’s great travel experiences. Take a guided tour of the ruins and stay at El Mapi Hotel for 1 night.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Machu Picchu\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZbv\",\"cityFrom\":{\"_ref\":\"geotree_city_252911\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3247,\"cityIDTo\":2990,\"cityNameFrom\":\"Sacred Valley\",\"cityNameTo\":\"Machu Picchu\",\"cityTo\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}],\"meals\":[\"breakfast\",\"dinner\"]},{\"_key\":\"4lXD1QprlKmqniOHajNZjp\",\"day\":5.1,\"dayTitle\":\"Transfer: Machu Picchu to Cuzco\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZnm\",\"cityFrom\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2990,\"cityIDTo\":4699,\"cityNameFrom\":\"Machu Picchu\",\"cityNameTo\":\"Cuzco\",\"cityTo\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}]},{\"_key\":\"4lXD1QprlKmqniOHajNZrj\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNa3a\",\"accommodation\":{\"_ref\":\"accommodation-33360\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNZvg\",\"city\":\"Cusco\",\"cityID\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":6,\"dayDescription\":\"\u003cp\u003eMorning at leisure (optional excursions available – please advise at time of booking if you wish to revisit the ruins) before returning to Cuzco. This ancient Inca capital has Spanish churches and mansions, which sit alongside Inca remains. Transfer to Los Portales Cuzco for 2 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Cuzco\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNZzd\",\"cityFrom\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2990,\"cityIDTo\":4699,\"cityNameFrom\":\"Machu Picchu\",\"cityNameTo\":\"Cuzco\",\"cityTo\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"4lXD1QprlKmqniOHajNa7X\",\"accommodations\":[{\"_key\":\"4lXD1QprlKmqniOHajNaJO\",\"accommodation\":{\"_ref\":\"accommodation-33360\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"4lXD1QprlKmqniOHajNaBU\",\"city\":\"Cusco\",\"cityID\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":7,\"dayDescription\":\"\u003cp\u003eMorning tour of the city. Optional visit to nearby ruins or a local museum.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Cuzco\",\"mapInfo\":[{\"_key\":\"4lXD1QprlKmqniOHajNaFR\",\"cityFrom\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"c
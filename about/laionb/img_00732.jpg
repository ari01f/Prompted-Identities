ributors\",\"url\":\"https://github.com/lucide-icons/lucide\"},\"collectionId\":\"lucide\",\"collectionName\":\"Lucide\",\"downloadUrl\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"sparkle\",\"license\":{\"name\":\"ISC\",\"url\":\"https://github.com/lucide-icons/lucide/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\",\"vFlip\":false}},\"name\":\"Generic\",\"position\":1},{\"_key\":\"NSXr7tAZasA1qyCnhRFezF\",\"description\":\"\u003cp\u003eTaste Georgian wine \u0026amp; brandy \u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"lucide:sparkle\",\"metadata\":{\"author\":{\"name\":\"Lucide Contributors\",\"url\":\"https://github.com/lucide-icons/lucide\"},\"collectionId\":\"lucide\",\"collectionName\":\"Lucide\",\"downloadUrl\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"sparkle\",\"license\":{\"name\":\"ISC\",\"url\":\"https://github.com/lucide-icons/lucide/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\",\"vFlip\":false}},\"name\":\"Generic\",\"position\":2},{\"_key\":\"NSXr7tAZasA1qyCnhRFf2M\",\"description\":\"\u003cp\u003eEnjoy a performance of Armenian spiritual music\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"lucide:sparkle\",\"metadata\":{\"author\":{\"name\":\"Lucide Contributors\",\"url\":\"https://github.com/lucide-icons/lucide\"},\"collectionId\":\"lucide\",\"collectionName\":\"Lucide\",\"downloadUrl\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"sparkle\",\"license\":{\"name\":\"ISC\",\"url\":\"https://github.com/lucide-icons/lucide/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\",\"vFlip\":false}},\"name\":\"Generic\",\"position\":3},{\"_key\":\"NSXr7tAZasA1qyCnhRFf5T\",\"description\":\"\u003cp\u003eMasterclass in making arishta, traditional Armenian pasta\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"lucide:sparkle\",\"metadata\":{\"author\":{\"name\":\"Lucide Contributors\",\"url\":\"https://github.com/lucide-icons/lucide\"},\"collectionId\":\"lucide\",\"collectionName\":\"Lucide\",\"downloadUrl\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"sparkle\",\"license\":{\"name\":\"ISC\",\"url\":\"https://github.com/lucide-icons/lucide/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/lucide:sparkle.svg?width=20\u0026height=20\",\"vFlip\":false}},\"name\":\"Generic\",\"position\":4}],\"includesInternalAir\":false,\"initialPrices\":[],\"journeyDetails\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFj0H\",\"description\":\"This itinerary can be taken privately on a date that suits you. Alternatively, it can be tailored to your exact requirements. So, should you want to spend longer in a particular location, or add another experience or destination, we can make all the arrangements for you. Please contact our travel specialists for guideline prices.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Private \u0026 tailor-made travel\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFj3O\",\"description\":\"Where a tour date shows ‘Guaranteed departure', this tour is guaranteed to run. For all other departure dates, once the minimum number of people booked has been reached, this tour is also guaranteed to run. Our sales consultants will be able to advise how many people are booked for your chosen date at the time of enquiry, giving you the confidence to book safe in the knowledge your tour will go ahead.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Guaranteed departures\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFj6V\",\"description\":\"Most Cox \u0026 Kings tours fall under this category and are based in 4- or 5-star accommodation where available, or the best alternative elsewhere.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Superior Tour\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFj9c\",\"description\":\"Unless otherwise stated, the tour prices and upgrade supplements are all per person in Euros, based on two people sharing a twin/double room. The online price is a guideline price.\",\"markets\":{\"au\":false,\"eu\":true,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Dates and Prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFjCj\",\"description\":\"Unless otherwise stated, the tour prices and upgrade supplements are all per person in pound sterling, based on two people sharing a twin/double room. The online price is a guideline price; your final quote may differ due to flight availability, and you may be asked to pay a flight supplement.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":true,\"us\":false,\"world\":false},\"title\":\"Dates and Prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFjFq\",\"description\":\"Higher-intensity activities, early starts, more uneven terrain and full-day excursions requiring good fitness and mobility.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Active activity level\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFjIx\",\"description\":\"Unless otherwise stated, the tour prices and upgrade supplements are all per person in Australian Dollars, based on two people sharing a twin/double room. The online price is a guideline price.\",\"markets\":{\"au\":true,\"eu\":false,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Dates and Prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhRFjM4\",\"description\":\"Unless otherwise stated, the tour prices and upgrade supplements are all per person in United States Dollars, based on two people sharing a twin/double room. The online price is a guideline price.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":false,\"us\":true,\"world\":true},\"title\":\"Dates and Prices\"}],\"lengthDays\":15,\"locations\":0,\"locationsType\":null,\"lowestPreviousPrices\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFejg\",\"currency\":\"AUD\",\"price\":6495},{\"_key\":\"NSXr7tAZasA1qyCnhRFemn\",\"currency\":\"GBP\",\"price\":2995},{\"_key\":\"NSXr7tAZasA1qyCnhRFepu\",\"currency\":\"EUR\",\"price\":2495},{\"_key\":\"NSXr7tAZasA1qyCnhRFet1\",\"currency\":\"USD\",\"price\":3096}],\"lowestPrices\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFZiO\",\"currency\":\"AUD\",\"price\":4696},{\"_key\":\"NSXr7tAZasA1qyCnhRFZlV\",\"currency\":\"USD\",\"price\":2971},{\"_key\":\"NSXr7tAZasA1qyCnhRFZoc\",\"currency\":\"GBP\",\"price\":2795},{\"_key\":\"NSXr7tAZasA1qyCnhRFZrj\",\"currency\":\"EUR\",\"price\":2320}],\"map\":\"https://stcontentprodeastus001.blob.core.windows.net/ecm/Renderings/434/P105431.svg\",\"mapJson\":\"$30\",\"maxDiscounts\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFeXE\",\"currency\":\"AUD\",\"price\":300},{\"_key\":\"NSXr7tAZasA1qyCnhRFeaL\",\"currency\":\"GBP\",\"price\":300},{\"_key\":\"NSXr7tAZasA1qyCnhRFedS\",\"currency\":\"EUR\",\"price\":175},{\"_key\":\"NSXr7tAZasA1qyCnhRFegZ\",\"currency\":\"USD\",\"price\":200}],\"offerFlags\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"offers\":[],\"overviewText\":\"Take an exciting journey across all three states of the southern Caucasus. Beginning in the oil-rich Muslim nation of Azerbaijan on the shores of the Caspian Sea, you will travel through Georgia, famous for its ancient monasteries and viticulture, and finish in the small, proud nation of Armenia, one of the oldest Christian countries in the world.\",\"packageTypeId\":4,\"people\":[],\"slug\":{\"_type\":\"slug\",\"current\":\"small-group-tour/across-the-southern-caucasus\"},\"subType\":\"Small Group Tour\",\"tags\":[],\"title\":\"Across the Southern Caucasus\",\"type\":\"Seat in Bus Brochure Tour\",\"year\":2026},{\"AkDestinationId\":245472,\"_createdAt\":\"2025-09-23T22:49:48Z\",\"_id\":\"journeys-package-105433\",\"_rev\":\"1oqnqg4II3NrNQE9vxsckZ\",\"_type\":\"journeys\",\"_updatedAt\":\"2026-02-27T14:32:01Z\",\"activityLevel\":\"Active\",\"advantages\":[{\"_key\":\"uqKP1CJoSsgXdCXPUunfbF\",\"description\":\"\u003cp\u003eHotel porterage\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"circum:circle-info\",\"metadata\":{\"author\":{\"name\":\"Klarr Agency\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons\"},\"collectionId\":\"circum\",\"collectionName\":\"Circum Icons\",\"downloadUrl\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 2.0\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\",\"vFlip\":false}},\"markets\":{\"au\":false,\"eu\":false,\"gb\":true,\"us\":false,\"world\":false},\"position\":11,\"title\":\"Custom\"},{\"_key\":\"uqKP1CJoSsgXdCXPUunfgU\",\"description\":\"\u003cp\u003eFarewell dinner\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"circum:circle-info\",\"metadata\":{\"author\":{\"name\":\"Klarr Agency\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons\"},\"collectionId\":\"circum\",\"collectionName\":\"Circum Icons\",\"downloadUrl\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 
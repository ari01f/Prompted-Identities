\"description\":\"Prices above are per person in Euros, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":false,\"eu\":true,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"bNKZj4hxI3qs1eUORv7hsX\",\"description\":\"Prices above are per person in pounds sterling (£), based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change due to external factors such as variable flight prices.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":true,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"bNKZj4hxI3qs1eUORv7hvq\",\"description\":\"Prices above are per person in Australian Dollars, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":true,\"eu\":false,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"bNKZj4hxI3qs1eUORv7hz9\",\"description\":\"Prices above are per person in United States Dollars, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":false,\"us\":true,\"world\":true},\"title\":\"Guideline prices\"}],\"lengthDays\":8,\"locations\":0,\"locationsType\":null,\"lowestPreviousPrices\":[],\"lowestPrices\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7i2S\",\"currency\":\"AUD\",\"price\":3495},{\"_key\":\"bNKZj4hxI3qs1eUORv7i5l\",\"currency\":\"EUR\",\"price\":1795},{\"_key\":\"bNKZj4hxI3qs1eUORv7i94\",\"currency\":\"GBP\",\"price\":1795},{\"_key\":\"bNKZj4hxI3qs1eUORv7iCN\",\"currency\":\"USD\",\"price\":2495}],\"map\":\"https://stcontentprodeastus001.blob.core.windows.net/ecm/Renderings/434/P105278.svg\",\"mapJson\":\"$34\",\"maxDiscounts\":[],\"offerFlags\":{\"au\":false,\"eu\":false,\"gb\":false,\"us\":false,\"world\":false},\"offers\":[],\"overviewText\":\"Tuscany sparked the Renaissance movement that reshaped culture – not only in Italy, but throughout Europe. Today, the region remains a trove of cultural treasures set in a bucolic landscape of rolling hills and slender cypresses. This tailor-made holiday reveals the highlights of the region, beginning in the UNESCO-listed heart of Florence. Travel by rail to Lucca for a walking tour of its attractive piazzas, and visit Siena, one of Italy’s best-preserved medieval towns.\",\"packageTypeId\":39,\"people\":[],\"slug\":{\"_type\":\"slug\",\"current\":\"tailor-made-journey/treasures-of-tuscany\"},\"subType\":\"Tailor-Made Journey\",\"tags\":[],\"title\":\"Treasures of Tuscany\",\"type\":\"Tailor Made Day by Day\",\"year\":null}],\"markets\":{\"asia\":true,\"au\":false,\"eu\":false,\"gb\":false,\"us\":false,\"world\":null},\"offers\":null,\"recommendationsByGroups\":null,\"sectionId\":\"marketing-tailormade-cards\",\"title\":\"Popular tailor-made holidays\",\"video\":null,\"videoDesktop\":null,\"videoMobile\":null},{\"_key\":\"53c4982d1bd2\",\"_type\":\"calendarGrid\",\"cardItems\":null,\"cssClass\":\"py-16\",\"gridItems\":[{\"_key\":\"e67ca59a838d\",\"_type\":\"textWithIllustration\",\"cta\":{\"_type\":\"cta\",\"route\":\"/inspiration/month-by-month/january\"},\"illustration\":{\"_type\":\"illustration\",\"alt\":\"Beach in Sri Lanka\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-58c3f5a2a7adec7cc7c02e199ad2cdf0d1657151-2560x1440-jpg\",\"_type\":\"reference\"}}},\"text\":[{\"_key\":\"9587c2f2c07c\",\"_type\":\"block\",\"children\":[{\"_key\":\"85fe2347b2f3\",\"_type\":\"span\",\"marks\":[],\"text\":\"January\"}],\"markDefs\":[],\"style\":\"h3\"}],\"title\":\"January\"},{\"_key\":\"a59750f47cb1\",\"_type\":\"textWithIllustration\",\"cta\":{\"_type\":\"cta\",\"route\":\"/inspiration/month-by-month/february\"},\"illustration\":{\"_type\":\"illustration\",\
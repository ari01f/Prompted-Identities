%2Fztdma7t1%2Fproduction%2F518192b37d4286d92bfb71f477597c86b8f9049d-1152x1440.jpg&amp;w=3840&amp;q=75"/><div class="z-1 absolute left-0 top-0 h-full w-full bg-gradient-to-t from-black/50 to-transparent"></div></div><div class="absolute left-0 top-0 z-10 flex h-full w-full flex-col justify-end px-[16px] pb-6"><div class="flex flex-col justify-between gap-2 text-center text-white"><h2 class="text-white">India</h2><div class="line-clamp-3"><p class="text-m">India: where cities sizzling with spice and chatter give way to serene hill stations, wide deserts and waterways.</p></div></div></div></a></div><div class="mantine-Carousel-slide mantine-1ka413v"><a class="relative flex h-full max-h-[382px] w-full flex-col gap-4 sm:max-h-[540px]" href="/destinations/far-east/japan"><div class="relative aspect-[0.7] h-[382px] w-full sm:h-[540px]"><img alt="Japan" loading="lazy" decoding="async" data-nimg="fill" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent" sizes="100vw" srcSet="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fc6cb35bf0a7bed8297da6e3cec80953add0168f6-4096x3072.jpg&amp;w=1440&amp;q=75 1440w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fc6cb35bf0a7bed8297da6e3cec80953add0168f6-4096x3072.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fc6cb35bf0a7bed8297da6e3cec80953add0168f6-4096x3072.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fc6cb35bf0a7bed8297da6e3cec80953add0168f6-4096x3072.jpg&amp;w=3840&amp;q=75 3840w" src="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fc6cb35bf0a7bed8297da6e3cec80953add0168f6-4096x3072.jpg&amp;w=3840&amp;q=75"/><div class="z-1 absolute left-0 top-0 h-full w-full bg-gradient-to-t from-black/50 to-transparent"></div></div><div class="absolute left-0 top-0 z-10 flex h-full w-full flex-col justify-end px-[16px] pb-6"><div class="flex flex-col justify-between gap-2 text-center text-white"><h2 class="text-white">Japan</h2><div class="line-clamp-3"><p class="text-m">Ancient temples, modern cities, and landscapes shaped by tradition and beauty.</p></div></div></div></a></div><div class="mantine-Carousel-slide mantine-1ka413v"><a class="relative flex h-full max-h-[382px] w-full flex-col gap-4 sm:max-h-[540px]" href="/destinations/south-america/peru"><div class="relative aspect-[0.7] h-[382px] w-full sm:h-[540px]"><img alt="Peru" loading="lazy" decoding="async" data-nimg="fill" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent" sizes="100vw" srcSet="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fa84283b7354b0a44c9b1f5eac83ec3994d420e1f-810x1440.jpg&amp;w=1440&amp;q=75 1440w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fa84283b7354b0a44c9b1f5eac83ec3994d420e1f-810x1440.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fa84283b7354b0a44c9b1f5eac83ec3994d420e1f-810x1440.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fa84283b7354b0a44c9b1f5eac83ec3994d420e1f-810x1440.jpg&amp;w=3840&amp;q=75 3840w" src="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Fa84283b7354b0a44c9b1f5eac83ec3994d420e1f-810x1440.jpg&amp;w=3840&amp;q=75"/><div class="z-1 absolute left-0 top-0 h-full w-full bg-gradient-to-t from-black/50 to-transparent"></div></div><div class="absolute left-0 top-0 z-10 flex h-full w-full flex-col justify-end px-[16px] pb-6"><div class="flex flex-col justify-between gap-2 text-center text-white"><h2 class="text-white">Peru</h2><div class="line-clamp-3"><p class="text-m">Machu Picchu is among the most breathtaking archaeological site in the world. Yet Peru also offers a wealth of other magnificent ancient, colonial and scenic sights.</p></div></div></div></a></div></div></div></div></div></div></section><section class="constrain-container"><div class="text-center w-full sm:max-w-[50%] mx-auto"><h2>Small Group Tours and Tailor-Made Holidays</h2><p></p><p></p><p></p><p></p><p></p><p></p><p>Cox &amp; Kings has over 265 years of experience arranging high quality travel to the world&#x27;s most captivating destinations. Whether you&#x27;re seeking culture, adventure or a blend of both, our holidays are designed by experts and brought to life by the finest guides.</p></div></section><section class="py-8"><div class="constrain-container"><div class="grid grid-cols-1 gap-8 sm:grid-cols-2"><a class="relative aspect-[0.7] h-full max-h-[320px] w-full sm:max-h-[540px]" href="/holiday-types/group-tours"><img alt="group-tours" loading="lazy" decoding="async" data-nimg="fill" class="h-full w-full" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent" sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 50vw" srcSet="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Ff4ddd27515f518cf9f12ddf76029bb501140b2a8-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=1440&amp;q=65 1440w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Ff4ddd27515f518cf9f12ddf76029bb501140b2a8-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=1920&amp;q=65 1920w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Ff4ddd27515f518cf9f12ddf76029bb501140b2a8-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=2048&amp;q=65 2048w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Ff4ddd27515f518cf9f12ddf76029bb501140b2a8-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=3840&amp;q=65 3840w" src="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2Ff4ddd27515f518cf9f12ddf76029bb501140b2a8-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=3840&amp;q=65"/><div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"><div class="absolute bottom-0 mb-6 w-full text-center text-white"><div class="mx-auto max-w-[80%]"><h2>Group tours</h2><p></p><p></p><p>Our high quality small group tours offer superb value – combining sightseeing with expert guides, signature experiences and free time to relax.</p></div></div></div></a><a class="relative aspect-[0.7] h-full max-h-[320px] w-full sm:max-h-[540px]" href="/holiday-types/tailor-made-holidays"><img alt="Tailor-made holidays" loading="lazy" decoding="async" data-nimg="fill" class="h-full w-full" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent" sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 50vw" srcSet="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2F4185d72851a2bedb1cb1cbd9fedf67e9573c3b78-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=1440&amp;q=65 1440w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2F4185d72851a2bedb1cb1cbd9fedf67e9573c3b78-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=1920&amp;q=65 1920w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2F4185d72851a2bedb1cb1cbd9fedf67e9573c3b78-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=2048&amp;q=65 2048w, /_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2F4185d72851a2bedb1cb1cbd9fedf67e9573c3b78-704x384.png%3Ffit%3Dmax%26auto%3Dformat&amp;w=3840&amp;q=65 3840w" src="/_next/image?url=https%3A%2F%2Fcdn.coxandkingstravel.com%2Fimages%2Fztdma7t1%2Fproduction%2F4185d72851a2bedb1cb1cbd9fedf67e9573c3b
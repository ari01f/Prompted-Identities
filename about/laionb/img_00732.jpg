eCar hire for the duration of the tour\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"circum:circle-info\",\"metadata\":{\"author\":{\"name\":\"Klarr Agency\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons\"},\"collectionId\":\"circum\",\"collectionName\":\"Circum Icons\",\"downloadUrl\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 2.0\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\",\"vFlip\":false}},\"markets\":{\"au\":true,\"eu\":true,\"gb\":false,\"us\":true,\"world\":true},\"position\":2,\"title\":\"Custom\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxd6S\",\"description\":\"\u003cp\u003eAccommodation, itinerary \u0026amp; meal basis as described\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"circum:circle-info\",\"metadata\":{\"author\":{\"name\":\"Klarr Agency\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons\"},\"collectionId\":\"circum\",\"collectionName\":\"Circum Icons\",\"downloadUrl\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 2.0\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\",\"vFlip\":false}},\"markets\":{\"au\":true,\"eu\":true,\"gb\":false,\"us\":true,\"world\":true},\"position\":1,\"title\":\"Custom\"}],\"bestTimeToGo\":\"Year-Round\",\"categories\":[\"Culture \u0026 History\",\"Self drive\",\"Luxury\",\"UNESCO Highlights\"],\"code\":\"\",\"da
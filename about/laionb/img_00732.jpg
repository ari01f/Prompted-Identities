e},\"cityIDFrom\":3348,\"cityIDTo\":3348,\"cityNameFrom\":\"Syracuse\",\"cityNameTo\":\"Syracuse\",\"cityTo\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"NSXr7tAZasA1qyCnhQxdho\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxdkv\",\"accommodation\":{\"_ref\":\"accommodation-169301\",\"_type\":\"reference\",\"_weak\":true},\"options\":[25128]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxdo2\",\"city\":\"Syracuse\",\"cityID\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":2,\"dayDescription\":\"\u003cp\u003eTake a morning city tour of Syracuse, including visits to the island of Ortygia. Your afternoon is at leisure.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Syracuse\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxdr9\",\"cityFrom\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3348,\"cityIDTo\":3348,\"cityNameFrom\":\"Syracuse\",\"cityNameTo\":\"Syracuse\",\"cityTo\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhQxduG\",\"day\":2.1,\"dayTitle\":\"Transfer: Syracuse to Ragusa\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxdxN\",\"cityFrom\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3348,\"cityIDTo\":4729,\"cityNameFrom\":\"Syracuse\",\"cityNameTo\":\"Ragusa\",\"cityTo\":{\"_ref\":\"geotree_city_253002\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhQxe0U\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxe3b\",\"accommodation\":{\"_ref\":\"accommodation-36011\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23253]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxe6i\",\"city\":\"Ragusa\",\"cityID\":{\"_ref\":\"geotree_city_253002\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":3,\"dayDescription\":\"\u003cp\u003eThis morning, drive to Ragusa, stopping en route in the baroque town of Noto. Stay for two nights at the Antica Badia Relais Hotel, an 18th-century palace and former residence of the founder of Ragusa.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Noto • Ragusa\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxe9p\",\"cityFrom\":{\"_ref\":\"geotree_city_250515\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3348,\"cityIDTo\":4729,\"cityNameFrom\":\"Syracuse\",\"cityNameTo\":\"Ragusa\",\"cityTo\":{\"_ref\":\"geotree_city_253002\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhQxeCw\",\"day\":3.1,\"dayTitle\":\"Transfer: Ragusa to Modica\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxeG3\",\"cityFrom\":{\"_ref\":\"geotree_city_253002\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4729,\"cityIDTo\":4730,\"cityNameFrom\":\"Ragusa\",\"cityNameTo\":\"Modica\",\"cityTo\":{\"_ref\":\"geotree_city_253005\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhQxeJA\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxeSV\",\"accommodation\":{\"_ref\":\"accommodation-36011\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23253]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxeMH\",\"city\":\"Modica\",\"cityID\":{\"_ref\":\"geotree_city_253005\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":4,\"dayDescription\":\"\u003cp\u003eDrive to the city of Modica, part of the UNESCO World Heritage Site of Val di Noto and grandly re-built following the region’s 1693 earthquake. The city is also famous for its chocolate, based on a recipe brought by the Spanish who once ruled Sicily.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Ragusa • Modica\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxePO\",\"cityFrom\":{\"_ref\":\"geotree_city_253002\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4729,\"cityIDTo\":4730,\"cityNameFrom\":\"Ragusa\",\"cityNameTo\":\"Modica\",\"cityTo\":{\"_ref\":\"geotree_city_253005\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhQxeVc\",\"day\":4.1,\"dayTitle\":\"Transfer: Modica to Agrigento\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxeYj\",\"cityFrom\":{\"_ref\":\"geotree_city_253005\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4730,\"cityIDTo\":2455,\"cityNameFrom\":\"Modica\",\"cityNameTo\":\"Agrigento\",\"cityTo\":{\"_ref\":\"geotree_city_246858\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhQxebq\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxelB\",\"accommodation\":{\"_ref\":\"accommodation-32553\",\"_type\":\"reference\",\"_weak\":true},\"options\":[23840]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxeex\",\"city\":\"Agrigento\",\"cityID\":{\"_ref\":\"geotree_city_246858\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":5,\"dayDescription\":\"\u003cp\u003eThis morning, drive to Agrigento. In the afternoon, tour the UNESCO World Heritage Site of the Valley of the Temples. Stay one night at Hotel Baglio Della Luna.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Agrigento\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxei4\",\"cityFrom\":{\"_ref\":\"geotree_city_253005\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4730,\"cityIDTo\":2455,\"cityNameFrom\":\"Modica\",\"cityNameTo\":\"Agrigento\",\"cityTo\":{\"_ref\":\"geotree_city_246858\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhQxeoI\",\"day\":5.1,\"dayTitle\":\"Transfer: Agrigento to Palermo\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxerP\",\"cityFrom\":{\"_ref\":\"geotree_city_246858\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2455,\"cityIDTo\":965,\"cityNameFrom\":\"Agrigento\",\"cityNameTo\":\"Palermo\",\"cityTo\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhQxeuW\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxf0k\",\"accommodation\":{\"_ref\":\"accommodation-12011\",\"_type\":\"reference\",\"_weak\":true},\"options\":[25160]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxf3r\",\"city\":\"Palermo, Sicily\",\"cityID\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":6,\"dayDescription\":\"\u003cp\u003eThis morning, drive to the capital of Sicily, Palermo. Your afternoon city tour including visits to the cathedral and Palatine Chapel. Stay two nights at Grand Hotel Piazza Borsa, situated in the heart of the city.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Palermo\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxexd\",\"cityFrom\":{\"_ref\":\"geotree_city_246858\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2455,\"cityIDTo\":965,\"cityNameFrom\":\"Agrigento\",\"cityNameTo\":\"Palermo\",\"cityTo\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhQxf6y\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxfGJ\",\"accommodation\":{\"_ref\":\"accommodation-12011\",\"_type\":\"reference\",\"_weak\":true},\"options\":[25160]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxfA5\",\"city\":\"Palermo, Sicily\",\"cityID\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":7,\"dayDescription\":\"\u003cp\u003eEnjoy your day at leisure, or take an optional tour to the Norman cathedral in Monreale.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Palermo\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxfDC\",\"cityFrom\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":965,\"cityIDTo\":965,\"cityNameFrom\":\"Palermo\",\"cityNameTo\":\"Palermo\",\"cityTo\":{\"_ref\":\"geotree_city_249614\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\"
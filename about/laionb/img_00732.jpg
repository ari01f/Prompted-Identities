gn/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 2.0\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\",\"vFlip\":false}},\"markets\":{\"au\":true,\"eu\":true,\"gb\":false,\"us\":true,\"world\":true},\"position\":1,\"title\":\"Custom\"}],\"bestTimeToGo\":\"Year-Round\",\"categories\":[\"Culture \u0026 History\",\"Rail\",\"Superior\",\"UNESCO Highlights\"],\"code\":\"\",\"dates\":[],\"dayByDay\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fDD\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fN8\",\"accommodation\":{\"_ref\":\"accommodation-154099\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24669]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fGW\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eArrive in Florence and transfer to Hotel Botticelli (upgraded room category) for 4 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Fly from the UK to Florence. \",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fJp\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":2745,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7fQR\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fX3\",\"accommodation\":{\"_ref\":\"accommodation-154099\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24669]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7faM\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly under own arrangements. Arrive in Florence and transfer to Hotel Botticelli (upgraded room category) for 4 nights. \u003c/p\u003e\u003cp\u003e\u003cem\u003eOur travel specialists will be delighted to assist with flight arrangements if required.\u003c/em\u003e\u003c/p\u003e\",\"dayLandOnly\":true,\"dayTitle\":\"Fly to Florence.\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fTk\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":2745,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7fdf\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fgy\",\"accommodation\":{\"_ref\":\"accommodation-154099\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24669]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fkH\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":2,\"dayDescription\":\"\u003cp\u003eEnjoy a day at leisure to wander Florence, the birthplace of the Renaissance. As you explore the compact UNESCO-listed centre, with its fountains, frescoes and fortified\u003cem\u003epalazzos\u003c/em\u003e, you will see why Florence is widely considered among the world’s most beautiful cities.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Florence\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fna\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":2745,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7fqt\",\"day\":2.1,\"dayTitle\":\"Transfer: Florence to Lucca\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7fuC\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":2974,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Lucca\",\"cityTo\":{\"_ref\":\"geotree_city_248950\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7fxV\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7g7Q\",\"accommodation\":{\"_ref\":\"accommodation-154099\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24669]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7g0o\",\"city\":\"Lucca\",\"cityID\":{\"_ref\":\"geotree_city_248950\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":3,\"dayDescription\":\"\u003cp\u003eTravel by train from Florence to Lucca, where you meet your guide for a walking tour of this charming walled city, followed by free time for lunch. Lucca was the birthplace of Giacomo Puccini and is as elegantly composed as his work. Experience the high notes at an \u003cem\u003eandante \u003c/em\u003epace, whether it’s the singular Guinigi Tower, the Romanesque duet of San Martino Cathedral and its campanile, or the ensemble of handsome, amber-hued buildings lining the \u003cem\u003epiazzas\u003c/em\u003e. Return to Florence in the late afternoon.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Lucca\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7g47\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":2974,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Lucca\",\"cityTo\":{\"_ref\":\"geotree_city_248950\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7gAj\",\"day\":3.1,\"dayTitle\":\"Transfer: Lucca to Florence\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gE2\",\"cityFrom\":{\"_ref\":\"geotree_city_248950\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2974,\"cityIDTo\":2745,\"cityNameFrom\":\"Lucca\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7gHL\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gKe\",\"accommodation\":{\"_ref\":\"accommodation-154099\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24669]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gNx\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":4,\"dayDescription\":\"\u003cp\u003eEnjoy a further day to experience the romance of Florence. Perhaps visit the UNESCO-listed gothic cathedral with its characteristic red-brick dome, or the treasure-filled Uffizi Gallery, where you can admire works by Michelangelo, Botticelli, Raphael and da Vinci. Beyond the landmarks, you can dine on Florentine delicacies at an authentic \u003cem\u003etrattoria\u003c/em\u003e, browse in the trend-setting boutiques, and sip espresso as you people-watch at a piazza-side café.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Florence\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gRG\",\"cityFrom\":{\"_ref\":\"geotree_city_248950\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2974,\"cityIDTo\":2745,\"cityNameFrom\":\"Lucca\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7gUZ\",\"day\":4.1,\"dayTitle\":\"Transfer: Florence to Siena\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gXs\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":3315,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Siena\",\"cityTo\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7gbB\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7ghn\",\"accommodation\":{\"_ref\":\"accommodation-154129\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24188]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gl6\",\"city\":\"Siena\",\"cityID\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":5,\"dayDescription\":\"\u003cp\u003eTransfer from Florence to Siena, one of Italy’s best-preserved medieval towns. En route, enjoy a guided tour of the fortified hilltop town of San Gimignano. Upon arrival in Siena, check in at Campo Regio Relais for 3 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Siena\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7geU\",\"cityFrom\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2745,\"cityIDTo\":3315,\"cityNameFrom\":\"Florence\",\"cityNameTo\":\"Siena\",\"cityTo\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7goP\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gyK\",\"accommodation\":{\"_ref\":\"accommodation-154129\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24188]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gri\",\"city\":\"Siena\",\"cityID\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":6,\"dayDescription\":\"\u003cp\u003eThis morning, take in Siena’s sights on a guided walking tour. Characterised by red-brick, gothic architecture, this pretty medieval city tumbles over three hills. It is home to the Piazza del Campo, a striking shell-shaped square that hosts the biannual Palio horse race and is overlooked by the 13th-century town hall and bell tower.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Siena\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7gv1\",\"cityFrom\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3315,\"cityIDTo\":3315,\"cityNameFrom\":\"Siena\",\"cityNameTo\":\"Siena\",\"cityTo\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7h1d\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hBY\",\"accommodation\":{\"_ref\":\"accommodation-154129\",\"_type\":\"reference\",\"_weak\":true},\"options\":[24188]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7h4w\",\"city\":\"Siena\",\"cityID\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":7,\"dayDescription\":\"\u003cp\u003eYour day is at leisure to enjoy more of Siena’s attractions. Consider visiting the Duomo di Siena, which dazzles with its vaulted, star-spangled ceiling and liquorice-striped belltower, not to mention the frescos of its library and crypt – the latter only unearthed in the 1990s. Other attractions include weekly street markets, several museums, and myriad restaurants, some in buildings as old as Siena’s most famous landmarks.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Siena\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7h8F\",\"cityFrom\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3315,\"cityIDTo\":3315,\"cityNameFrom\":\"Siena\",\"cityNameTo\":\"Siena\",\"cityTo\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7hEr\",\"day\":7.1,\"dayTitle\":\"Transfer: Siena to Florence\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hIA\",\"cityFrom\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3315,\"cityIDTo\":2745,\"cityNameFrom\":\"Siena\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORv7hLT\",\"accommodations\":[],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hOm\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":8,\"dayDescription\":\"\u003cp\u003eTransfer to Florence Airport for your flight.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Fly back to the UK.\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hS5\",\"cityFrom\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3315,\"cityIDTo\":2745,\"cityNameFrom\":\"Siena\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORv7hVO\",\"accommodations\":[],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hYh\",\"city\":\"Florence\",\"cityID\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":8,\"dayDescription\":\"\u003cp\u003eTransfer to Florence Airport for your flight under own arrangement.\u003c/p\u003e\",\"dayLandOnly\":true,\"dayTitle\":\"Fly back home.\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7hc0\",\"cityFrom\":{\"_ref\":\"geotree_city_250356\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3315,\"cityIDTo\":2745,\"cityNameFrom\":\"Siena\",\"cityNameTo\":\"Florence\",\"cityTo\":{\"_ref\":\"geotree_city_248007\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]}],\"goodwillDisclaimer\":\"\",\"groupSize\":99,\"hasAvailableDates\":true,\"heroImages\":[{\"_key\":\"7eea5743ea2bc7ecec8996d8f71e8eee2b7a67fd-1772595251299\",\"_type\":\"illustration\",\"alt\":\"abercrombie kent Treasures of Tuscany-1\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-7eea5743ea2bc7ecec8996d8f71e8eee2b7a67fd-2560x1440-jpg\",\"_type\":\"reference\"}}}],\"heroImagesMobile\":[{\"_key\":\"6a86c9ef8b8ea206a1e085183289326f44591ef2-1772595251430\",\"_type\":\"illustration\",\"alt\":\"abercrombie kent Treasures of Tuscany-1\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-6a86c9ef8b8ea206a1e085183289326f44591ef2-810x1440-jpg\",\"_type\":\"reference\"}}}],\"highlightImages\":[{\"_key\":\"c3b4523be36c7cbbcb7d045c8bd50b
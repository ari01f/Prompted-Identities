ptions\":[158394]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnOc\",\"city\":\"Lima\",\"cityID\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly from London (regional connections available) to Lima and transfer to the Country Club Lima Hotel.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Fly to Lima\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnRv\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":4698,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Lima\",\"cityTo\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYnYX\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYniS\",\"accommodation\":{\"_ref\":\"accommodation-28596\",\"_type\":\"reference\",\"_weak\":true},\"options\":[158394]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnbq\",\"city\":\"Lima\",\"cityID\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly to Lima under your own arrangements and transfer to the Country Club Lima Hotel. \u003cem\u003eOur travel specialists will be delighted to assist with flight arrangements if required.\u003c/em\u003e\u003c/p\u003e\",\"dayLandOnly\":true,\"dayTitle\":\"Fly to Lima\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnf9\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":4698,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Lima\",\"cityTo\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYnll\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnvg\",\"accommodation\":{\"_ref\":\"accommodation-28596\",\"_type\":\"reference\",\"_weak\":true},\"options\":[158394]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnp4\",\"city\":\"Lima\",\"cityID\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":2,\"dayDescription\":\"\u003cp\u003eTake a half-day city tour, including Casa Aliaga, the oldest colonial mansion in Lima, and the architectural masterpiece of San Francisco monastery.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Lima\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYnsN\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":4698,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Lima\",\"cityTo\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYnyz\",\"day\":2.1,\"dayTitle\":\"Transfer: Lima to Arequipa\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYo2I\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":2496,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Arequipa\",\"cityTo\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Flight\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYo5b\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoFW\",\"accommodation\":{\"_ref\":\"accommodation-33004\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157650]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYo8u\",\"city\":\"Arequipa\",\"cityID\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":3,\"dayDescription\":\"\u003cp\u003eFly over the Andes to Arequipa, a city of white buildings and colonnaded plazas surrounded by ice-capped volcanoes. Transfer to the Costa del Sol Wyndham for 2 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Fly to Arequipa\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoCD\",\"cityFrom\":{\"_ref\":\"geotree_city_248859\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4698,\"cityIDTo\":2496,\"cityNameFrom\":\"Lima\",\"cityNameTo\":\"Arequipa\",\"cityTo\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Flight\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYoIp\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoSk\",\"accommodation\":{\"_ref\":\"accommodation-33004\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157650]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoM8\",\"city\":\"Arequipa\",\"cityID\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":4,\"dayDescription\":\"\u003cp\u003eFull-day city tour, including the beautiful Santa Catalina convent, which dates from the 16th century, and the Juanita Mummy Museum.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Arequipa\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoPR\",\"cityFrom\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2496,\"cityIDTo\":2496,\"cityNameFrom\":\"Arequipa\",\"cityNameTo\":\"Arequipa\",\"cityTo\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYoW3\",\"day\":4.1,\"dayTitle\":\"Transfer: Arequipa to Colca Canyon\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoZM\",\"cityFrom\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2496,\"cityIDTo\":5864,\"cityNameFrom\":\"Arequipa\",\"cityNameTo\":\"Colca Canyon\",\"cityTo\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYocf\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYoma\",\"accommodation\":{\"_ref\":\"accommodation-33006\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYofy\",\"city\":\"Arequipa\",\"cityID\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":5,\"dayDescription\":\"\u003cp\u003eDrive into the Andes towards Colca Canyon (approx. 4 hours, partly on unpaved roads, with stops en route). The scenery is breathtaking, with the terraces of the Colca Valley and herds of llamas scattered around. Stay for 2 nights at Colca Lodge Spa \u0026amp; Hot Springs.\u003cbr\u003e\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Colca Canyon\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYojH\",\"cityFrom\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2496,\"cityIDTo\":5864,\"cityNameFrom\":\"Arequipa\",\"cityNameTo\":\"Colca Canyon\",\"cityTo\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYopt\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYotC\",\"accommodation\":{\"_ref\":\"accommodation-33006\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYowV\",\"city\":\"Arequipa\",\"cityID\":{\"_ref\":\"geotree_city_246991\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":6,\"dayDescription\":\"\u003cp\u003eEarly morning excursion to Condor’s Cross to see magnificent condors flying over the canyon. Visit the town of Maca, famed for its pre-Columbian textiles. Afternoon at leisure.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Colca Canyon\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYozo\",\"cityFrom\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5864,\"cityIDTo\":5864,\"cityNameFrom\":\"Colca Canyon\",\"cityNameTo\":\"Colca Canyon\",\"cityTo\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYp37\",\"day\":6.1,\"dayTitle\":\"Transfer: Colca Canyon to Puno\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYp6Q\",\"cityFrom\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5864,\"cityIDTo\":5257,\"cityNameFrom\":\"Colca Canyon\",\"cityNameTo\":\"Puno\",\"cityTo\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYp9j\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpJe\",\"accommodation\":{\"_ref\":\"accommodation-33007\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157650]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpD2\",\"city\":\"Lake Titicaca\",\"cityID\":{\"_ref\":\"geotree_city_248791\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":7,\"dayDescription\":\"\u003cp\u003eTravel by road to Puno and Lake Titicaca (approx. 6 hours). Stay 2 nights at the GHL Hotel Lago Titicaca on the shore of the lake.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Lake Titicaca\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpGL\",\"cityFrom\":{\"_ref\":\"geotree_city_254305\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5864,\"cityIDTo\":5257,\"cityNameFrom\":\"Colca Canyon\",\"cityNameTo\":\"Puno\",\"cityTo\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYpMx\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpWs\",\"accommodation\":{\"_ref\":\"accommodation-33007\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157650]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpQG\",\"city\":\"Lake Titicaca\",\"cityID\":{\"_ref\":\"geotree_city_248791\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":8,\"dayDescription\":\"\u003cp\u003eTake a full-day tour of the floating Uros reed islands and Taquile Island.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Lake Titicaca\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpTZ\",\"cityFrom\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5257,\"cityIDTo\":5257,\"cityNameFrom\":\"Puno\",\"cityNameTo\":\"Puno\",\"cityTo\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYpaB\",\"day\":8.1,\"dayTitle\":\"Transfer: Puno to Cuzco\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpdU\",\"cityFrom\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5257,\"cityIDTo\":4699,\"cityNameFrom\":\"Puno\",\"cityNameTo\":\"Cuzco\",\"cityTo\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYpgn\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpk6\",\"accommodation\":{\"_ref\":\"accommodation-33131\",\"_type\":\"reference\",\"_weak\":true},\"options\":[158606]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpnP\",\"city\":\"Cusco Region\",\"cityID\":{\"_ref\":\"geotree_region_245851\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":9,\"dayDescription\":\"\u003cp\u003eTake the stylish Titicaca train to Cuzco (approximately 10 hours). Relax over lunch or with a pisco sour in the observation car as you pass through rolling Andean plains where vicuñas and alpacas may be seen. Overnight at Palacio del Inka, a Luxury Collection Hotel.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Train to Cuzco\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpqi\",\"cityFrom\":{\"_ref\":\"geotree_city_249910\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":5257,\"cityIDTo\":4699,\"cityNameFrom\":\"Puno\",\"cityNameTo\":\"Cuzco\",\"cityTo\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Train\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYpu1\",\"day\":9.1,\"dayTitle\":\"Transfer: Cuzco to Machu Picchu\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYpxK\",\"cityFrom\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4699,\"cityIDTo\":2990,\"cityNameFrom\":\"Cuzco\",\"cityNameTo\":\"Machu Picchu\",\"cityTo\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"bNKZj4hxI3qs1eUORvYq0d\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYqAY\",\"accommodation\":{\"_ref\":\"accommodation-11977\",\"_type\":\"reference\",\"_weak\":true},\"options\":[163146]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYq3w\",\"city\":\"Cusco Region\",\"cityID\":{\"_ref\":\"geotree_region_245851\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":10,\"dayDescription\":\"\u003cp\u003eTravel by road to the indigenous village of Chinchero to see its Inca terraces and a traditional weaving demonstration. Continue to the Sacred Valley and stay 2 nights at Inkaterra Hacienda Urubamba.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Chinchero - Sacred Valley\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYq7F\",\"cityFrom\":{\"_ref\":\"geotree_city_247735\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4699,\"cityIDTo\":2990,\"cityNameFrom\":\"Cuzco\",\"cityNameTo\":\"Machu Picchu\",\"cityTo\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"bNKZj4hxI3qs1eUORvYqDr\",\"accommodations\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYqHA\",\"accommodation\":{\"_ref\":\"accommodation-11977\",\"_type\":\"reference\",\"_weak\":true},\"options\":[163146]}],\"cities\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYqKT\",\"city\":\"Cusco Region\",\"cityID\":{\"_ref\":\"geotree_region_245851\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":11,\"dayDescription\":\"\u003cp\u003eHalf-day visit to the Inca fortress at Ollantaytambo, an astounding feat of construction and ingenuity. Afternoon at leisure.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Sacred Valley\",\"mapInfo\":[{\"_key\":\"bNKZj4hxI3qs1eUORvYqNm\",\"cityFrom\":{\"_ref\":\"geotree_city_248986\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2990,\"cityIDTo\":2990,\"cityNameFrom\":\"Machu Picchu\",\"cityNameTo\":\"Machu Picchu\",\"cityTo\":{\"_ref\
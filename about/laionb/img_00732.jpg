y\":\"NSXr7tAZasA1qyCnhQxcYD\",\"airPrice\":0,\"callForPrice\":false,\"companyID\":2900,\"currency\":\"USD\",\"dateFrom\":\"2025-03-01T00:00:00\",\"dateTo\":\"2025-03-31T00:00:00\",\"display\":true,\"internalAir\":false,\"internalAirNotes\":null,\"note\":\"Prices are per person, double occupancy and subject to change.\",\"permit\":false,\"permitPrice\":0,\"price\":2095,\"singleSupplementPrice\":0},{\"_key\":\"NSXr7tAZasA1qyCnhQxcbK\",\"airPrice\":0,\"callForPrice\":false,\"companyID\":2900,\"currency\":\"USD\",\"dateFrom\":\"2025-04-01T00:00:00\",\"dateTo\":\"2025-04-30T00:00:00\",\"display\":false,\"internalAir\":false,\"internalAirNotes\":null,\"note\":\"Prices are per person, double occupancy and subject to change.\",\"permit\":false,\"permitPrice\":0,\"price\":2195,\"singleSupplementPrice\":0}],\"journeyDetails\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxg7E\",\"description\":\"These are our most comfortable tours and will usually feature 5-star deluxe accommodation throughout\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Luxury Tour\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgAL\",\"description\":\"Medium pace, some  longer travel days, with uneven terrain and  longer walks requiring good fitness  and mobility.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Moderate activity level\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgDS\",\"description\":\"For a price quote based on alternative accommodation standards, to discuss flight options or to tailor this itinerary, please call to speak with a Cox \u0026 Kings consultant or enquire online.\",\"markets\":{\"au\":true,\"eu\":true,\"gb\":true,\"us\":true,\"world\":true},\"title\":\"Tailor-made travel\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgGZ\",\"description\":\"Prices above are per person in Euros, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":false,\"eu\":true,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgJg\",\"description\":\"Prices above are per person in pounds sterling (£), based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change due to external factors such as variable flight prices.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":true,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgMn\",\"description\":\"Prices above are per person in Australian Dollars, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":true,\"eu\":false,\"gb\":false,\"us\":false,\"world\":false},\"title\":\"Guideline prices\"},{\"_key\":\"NSXr7tAZasA1qyCnhQxgPu\",\"description\":\"Prices above are per person in United States Dollars, based on two people sharing a twin/double-room. Single supplement available on request. Pricing is indicative and may be subject to change.\",\"markets\":{\"au\":false,\"eu\":false,\"gb\":false,\"us\":true,\"world\":true},\"title\":\"Guideline prices\"}],\"lengthDays\":10,\"locations\":0,\"locationsType\":null,\"lowestPreviousPrices\":[],\"lowestPrices\":[{\"_key\":\"NSXr7tAZasA1qyCnhQxc35\",\"currency\":\"AUD\",\"price\":2895},{\"_key\":\"NSXr7tAZasA1qyCnhQxc6C\",\"currency\":\"EUR\",\"price\":3695},{\"_key\":\"NSXr7tAZasA1qyCnhQxc9J\",\"currency\":\"GBP\",\"price\":3795},{\"_key\":\"NSXr7tAZasA1qyCnhQxcCQ\",\"currency\":\"USD\",\"price\":2095}],\"map\":\"https://stcontentprodeastus001.blob.core.windows.net/ecm/Renderings/434/P105187.svg\",\"mapJson\":\"$33\",\"maxDiscounts\":[],\"offerFlags\":{\"au\":false,\"eu\":false,\"gb\":false,\"us\":false,\"world\":false},\"offers\":[],\"overviewText\":\"This self-drive journey plots a circular course around Sicily, skirting the coast between UNESCO sites and attractive cities. Visit Syracuse, famed for its Greek and Roman heritage; tour the historic region of Val di Noto, home to handsome baroque architecture; explore Palermo, the island’s capital; as well as pretty Taormina on the coast. Throughout, you are accommodated in historic manors, boutique townhouses, and even a former palace.\",\"packageTypeId\":39,\"people\":[],\"slug\":{\"_type\":\"slug\",\"current\":\"tailor-made-journey/sicilian-explorer\"},\"subType\":\"Tailor-Made Journey\",\"tags\":[],\"title\":\"Sicilian Explorer\",\"type\":\"Tailor Made Day by Day\",\"year\":null},{\"AkDestinationId\":97,\"_createdAt\":\"2025-09-23T22:46:00Z\",\"_id\":\"journeys-package-105278\",\"_rev\":\"bNKZj4hxI3qs1eUORv7f6b\",\"_type\":\"journeys\",\"_updatedAt\":\"2026-03-04T03:34:12Z\",\"activityLevel\":\"Moderate\",\"advantages\":[{\"_key\":\"bNKZj4hxI3qs1eUORv7iFg\",\"description\":\"\u003cp\u003eLocal guides \u0026amp; entrance fees where applicable\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"circum:circle-info\",\"metadata\":{\"author\":{\"name\":\"Klarr Agency\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons\"},\"collectionId\":\"circum\",\"collectionName\":\"Circum Icons\",\"downloadUrl\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\u0026download=1\",\"flip\":\"\",\"hFlip\":false,\"iconName\":\"circle-info\",\"license\":{\"name\":\"Mozilla Public License 2.0\",\"url\":\"https://github.com/Klarr-Agency/Circum-Icons/blob/main/LICENSE\"},\"palette\":false,\"rotate\":0,\"size\":{\"height\":20,\"width\":20},\"url\":\"https://api.iconify.design/circum:circle-info.svg?width=20\u0026height=20\",\"vFlip\":false}},\"markets\":{\"au\":false,\"eu\":false,\"gb\":true,\"us\":false,\"world\":false},\"position\":4,\"title\":\"Custom\"},{\"_key\":\"bNKZj4hxI3qs1eUORv7iIz\",\"description\":\"\u003cp\u003eThe support (if required) of an English-speaking local representative\u003c/p\u003e\",\"icon\":{\"_type\":\"icon.manager\",\"icon\":\"c
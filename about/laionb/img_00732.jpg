]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfHv\",\"city\":\"Baku\",\"cityID\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly to Baku under your own arrangements . Transfer to Mercure Hotel (or similar) for 2 nights. \u003cem\u003eOur travel specialists will be delighted to assist with flight arrangements if required.\u003c/em\u003e\u003c/p\u003e\",\"dayLandOnly\":true,\"dayTitle\":\"Fly to Baku, Azerbaijan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfBh\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":2522,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Baku\",\"cityTo\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFfL2\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfUN\",\"accommodation\":{\"_ref\":\"accommodation-35141\",\"_type\":\"reference\",\"_weak\":true},\"options\":[30895]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfO9\",\"city\":\"Baku\",\"cityID\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":1,\"dayDescription\":\"\u003cp\u003eFly from London (regional connections available) to Baku via Istanbul, Turkey, with Turkish Airlines. Transfer to Mercure Hotel (or similar) for 2 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Arrive Baku\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfRG\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":2522,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Baku\",\"cityTo\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFfXU\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfgp\",\"accommodation\":{\"_ref\":\"accommodation-35141\",\"_type\":\"reference\",\"_weak\":true},\"options\":[30895]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfab\",\"city\":\"Baku\",\"cityID\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":2,\"dayDescription\":\"\u003cp\u003eEnjoy an afternoon sightseeing tour of Baku.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Baku\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfdi\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":2522,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Baku\",\"cityTo\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFfjw\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFftH\",\"accommodation\":{\"_ref\":\"accommodation-35141\",\"_type\":\"reference\",\"_weak\":true},\"options\":[30895]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfn3\",\"city\":\"Baku\",\"cityID\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":3,\"dayDescription\":\"\u003cp\u003eAdmire Gobustan’s 20,000-year-old rock carvings. Enjoy an excursion to Absheron to see the Ateshgah Fire Temple and Yanar Dagh fire. In the evening, enjoy a welcome dinner.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Gobustan - Absheron\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfqA\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":2522,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Baku\",\"cityTo\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\",\"dinner\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFfwO\",\"day\":3.1,\"dayTitle\":\"Transfer: Baku to Sheki\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFfzV\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":4724,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Sheki\",\"cityTo\":{\"_ref\":\"geotree_city_253448\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFg2c\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFg8q\",\"accommodation\":{\"_ref\":\"accommodation-35136\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgBx\",\"city\":\"Sheki\",\"cityID\":{\"_ref\":\"geotree_city_253448\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":4,\"dayDescription\":\"\u003cp\u003eVisit the Yeddi Gumbez mausoleum in Shemahka. Continue to Shaki, stopping en route at a sixth-century Albanian church. Overnight at Hotel Macara Sheki (or similar).\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Shemahka - Kish - Shaki\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFg5j\",\"cityFrom\":{\"_ref\":\"geotree_city_247079\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":2522,\"cityIDTo\":4724,\"cityNameFrom\":\"Baku\",\"cityNameTo\":\"Sheki\",\"cityTo\":{\"_ref\":\"geotree_city_253448\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\",\"dinner\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFgF4\",\"day\":4.1,\"dayTitle\":\"Transfer: Sheki to Telavi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgIB\",\"cityFrom\":{\"_ref\":\"geotree_city_253448\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4724,\"cityIDTo\":3637,\"cityNameFrom\":\"Sheki\",\"cityNameTo\":\"Telavi\",\"cityTo\":{\"_ref\":\"geotree_city_253963\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFgLI\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgUd\",\"accommodation\":{\"_ref\":\"accommodation-154768\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgOP\",\"city\":\"Telavi\",\"cityID\":{\"_ref\":\"geotree_region_253963\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":5,\"dayDescription\":\"\u003cp\u003eTour Shaki, scenically set in the Caucasus foothills, including its 18th-century palace. Cross the border into Georgia for a vineyard lunch and wine tasting. Continue to Telavi via the Gremi monastic complex. Overnight at Holiday Inn Telavi (or similar).\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Shaki - Kvareli - Telavi, Georgia\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgRW\",\"cityFrom\":{\"_ref\":\"geotree_city_253448\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4724,\"cityIDTo\":3637,\"cityNameFrom\":\"Sheki\",\"cityNameTo\":\"Telavi\",\"cityTo\":{\"_ref\":\"geotree_city_253963\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\",\"dinner\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFgXk\",\"day\":5.1,\"dayTitle\":\"Transfer: Telavi to Tbilisi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgar\",\"cityFrom\":{\"_ref\":\"geotree_city_253963\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3637,\"cityIDTo\":3636,\"cityNameFrom\":\"Telavi\",\"cityNameTo\":\"Tbilisi\",\"cityTo\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFgdy\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgh5\",\"accommodation\":{\"_ref\":\"accommodation-154596\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgkC\",\"city\":\"Tbilisi\",\"cityID\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":6,\"dayDescription\":\"\u003cp\u003eMorning visit to Telavi market. Meet a qvevri master, who will demonstrate how these large earthenware wine-keeping jars are made. Sample local wine and ‘fire-water’ brandy before lunch at Tsinandali wine estate. This afternoon, tour the hilltop town of Sighnaghi. Drive to Tbilisi and stay at the Artizan Design Hotel (or similar) for 2 nights.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Telavi - Sighnaghi - Tbilisi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgnJ\",\"cityFrom\":{\"_ref\":\"geotree_city_253963\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3637,\"cityIDTo\":3636,\"cityNameFrom\":\"Telavi\",\"cityNameTo\":\"Tbilisi\",\"cityTo\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFgqQ\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgzl\",\"accommodation\":{\"_ref\":\"accommodation-154596\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgtX\",\"city\":\"Tbilisi\",\"cityID\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":7,\"dayDescription\":\"\u003cp\u003eTour the Georgian capital, including the Old Town, with its beautiful Orthodox churches, mosque, synagogue and sulphur baths. Your afternoon is at leisure.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Tbilisi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFgwe\",\"cityFrom\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3636,\"cityIDTo\":3636,\"cityNameFrom\":\"Tbilisi\",\"cityNameTo\":\"Tbilisi\",\"cityTo\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFh2s\",\"day\":7.1,\"dayTitle\":\"Transfer: Tbilisi to Kazbegi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFh5z\",\"cityFrom\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3636,\"cityIDTo\":4633,\"cityNameFrom\":\"Tbilisi\",\"cityNameTo\":\"Kazbegi\",\"cityTo\":{\"_ref\":\"geotree_city_248582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFh96\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhCD\",\"accommodation\":{\"_ref\":\"accommodation-32358\",\"_type\":\"reference\",\"_weak\":true},\"options\":[30222]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhFK\",\"city\":\"Kazbegi\",\"cityID\":{\"_ref\":\"geotree_city_248582\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":8,\"dayDescription\":\"\u003cp\u003eVisit the sixth-century Jvari Monastery, followed by Mtskheta, then continue to Gori, birthplace of Joseph Stalin. See the museum, his private train, and the house where he was born. Travel to Kazbegi via the cave city of Uplistsikhe, set on the path of the Silk Road. Overnight at Hotel Porta Caucasia (or similar).\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Gori - Uplistsikhe - Kazbegi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhIR\",\"cityFrom\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3636,\"cityIDTo\":4633,\"cityNameFrom\":\"Tbilisi\",\"cityNameTo\":\"Kazbegi\",\"cityTo\":{\"_ref\":\"geotree_city_248582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"dinner\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFhLY\",\"day\":8.1,\"dayTitle\":\"Transfer: Kazbegi to Tbilisi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhOf\",\"cityFrom\":{\"_ref\":\"geotree_city_248582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4633,\"cityIDTo\":3636,\"cityNameFrom\":\"Kazbegi\",\"cityNameTo\":\"Tbilisi\",\"cityTo\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFhRm\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhY0\",\"accommodation\":{\"_ref\":\"accommodation-154596\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhb7\",\"city\":\"Tbilisi\",\"cityID\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":9,\"dayDescription\":\"\u003cp\u003eExcursion on foot to the picturesque 14thcentury church of Gergeti Trinity. Return to Tbilisi for time at leisure.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Kazbegi - Tbilisi\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhUt\",\"cityFrom\":{\"_ref\":\"geotree_city_248582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":4633,\"cityIDTo\":3636,\"cityNameFrom\":\"Kazbegi\",\"cityNameTo\":\"Tbilisi\",\"cityTo\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFheE\",\"day\":9.1,\"dayTitle\":\"Transfer: Tbilisi to Yerevan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhhL\",\"cityFrom\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3636,\"cityIDTo\":3450,\"cityNameFrom\":\"Tbilisi\",\"cityNameTo\":\"Yerevan\",\"cityTo\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFhkS\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhtn\",\"accommodation\":{\"_ref\":\"accommodation-35291\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhnZ\",\"city\":\"Yerevan\",\"cityID\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":10,\"dayDescription\":\"\u003cp\u003eCross the Armenian border and continue to the UNESCO-listed Haghpat Monastery, a masterpiece of Armenian architecture. Stay 4 nights at Tufenkian Historic Hotel (or similar), just off Yerevan’s Republic Square.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Yerevan, Armenia\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFhqg\",\"cityFrom\":{\"_ref\":\"geotree_city_250582\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3636,\"cityIDTo\":3450,\"cityNameFrom\":\"Tbilisi\",\"cityNameTo\":\"Yerevan\",\"cityTo\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFhwu\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFi6F\",\"accommodation\":{\"_ref\":\"accommodation-35291\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFi01\",\"city\":\"Yerevan\",\"cityID\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":11,\"dayDescription\":\"\u003cp\u003eVisit Echmiatsin Cathedral, founded in 303AD and still the official residence of the Catholic Church in Armenia. Continue to the seventh-century Zvartnots Temple. Have lunch in the village of Parakar and take part in a cooking lesson, learning how to make arishta (traditional Armenian pasta) and sweet sudzukh.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Echmiatsin – Zvarnots\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFi38\",\"cityFrom\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3450,\"cityIDTo\":3450,\"cityNameFrom\":\"Yerevan\",\"cityNameTo\":\"Yerevan\",\"cityTo\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFi9M\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiIh\",\"accommodation\":{\"_ref\":\"accommodation-35291\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiCT\",\"city\":\"Yerevan\",\"cityID\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":12,\"dayDescription\":\"\u003cp\u003eTour Yerevan, one of the world’s oldest continuously inhabited cities. Visit the city’s museum of ancient manuscripts, and the genocide memorial complex.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Yerevan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiFa\",\"cityFrom\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3450,\"cityIDTo\":3450,\"cityNameFrom\":\"Yerevan\",\"cityNameTo\":\"Yerevan\",\"cityTo\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFiLo\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiS2\",\"accommodation\":{\"_ref\":\"accommodation-35291\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiV9\",\"city\":\"Yerevan\",\"cityID\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":13,\"dayDescription\":\"\u003cp\u003eTravel to Khor Virap monastery, where Armenia’s patron saint, Gregory the Illuminator, was imprisoned. Savour views of the Ararat Mountain, then continue to Noravank monastery, dramatically situated within a gorge. Visit the wine-producingvillage of Areni for lunch. Return to Yerevan. Attend dinner with folk music at an Armenian restaurant.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Khor Virap – Noravank – Yerevan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiOv\",\"cityFrom\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3450,\"cityIDTo\":3450,\"cityNameFrom\":\"Yerevan\",\"cityNameTo\":\"Yerevan\",\"cityTo\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\",\"lunch\",\"dinner\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFiYG\",\"day\":13.1,\"dayTitle\":\"Transfer: Yerevan to Dilijan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFibN\",\"cityFrom\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3450,\"cityIDTo\":3581,\"cityNameFrom\":\"Yerevan\",\"cityNameTo\":\"Dilijan\",\"cityTo\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}]},{\"_key\":\"NSXr7tAZasA1qyCnhRFieU\",\"accommodations\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFinp\",\"accommodation\":{\"_ref\":\"accommodation-35293\",\"_type\":\"reference\",\"_weak\":true},\"options\":[157626]}],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFihb\",\"city\":\"Dilijan\",\"cityID\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":14,\"dayDescription\":\"\u003cp\u003eVisit Garni, Armenia’s only surviving Hellenistic temple, then attend a performance of spiritual music. Admire the basalt formations of Garni Gorge, before continuing to the fourth-century, mountain-carved monastery of Geghard. Enjoy lunch with alocal family and a lavash bread-making lesson, then visit two 10th-century monasteries. Drive to Dilijan and overnight at the Best Western Paradise (or similar). Farewell drink with your group.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Garni - Geghard - Dilijan\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiki\",\"cityFrom\":{\"_ref\":\"geotree_city_250977\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3450,\"cityIDTo\":3581,\"cityNameFrom\":\"Yerevan\",\"cityNameTo\":\"Dilijan\",\"cityTo\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true},\"transferType\":\"Road\"}],\"meals\":[\"breakfast\",\"lunch\"]},{\"_key\":\"NSXr7tAZasA1qyCnhRFiqw\",\"accommodations\":[],\"cities\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFiu3\",\"city\":\"Dilijan\",\"cityID\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true}}],\"day\":15,\"dayDescription\":\"\u003cp\u003eMorning stroll in Dilijan followed by a visit to Goshavank Monastery and its green and pleasant surrounds. Drive to Tbilisi Airport for your flight home.\u003c/p\u003e\",\"dayLandOnly\":false,\"dayTitle\":\"Dilijan - Goshavank - Tbilisi, Georgia\",\"mapInfo\":[{\"_key\":\"NSXr7tAZasA1qyCnhRFixA\",\"cityFrom\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true},\"cityIDFrom\":3581,\"cityIDTo\":3581,\"cityNameFrom\":\"Dilijan\",\"cityNameTo\":\"Dilijan\",\"cityTo\":{\"_ref\":\"geotree_city_253921\",\"_type\":\"reference\",\"_weak\":true}}],\"meals\":[\"breakfast\"]}],\"goodwillDisclaimer\":\"\",\"groupSize\":18,\"hasAvailableDates\":true,\"heroImages\":[{\"_key\":\"cb4835daaef7dd330614accdd09eefd0f5a6b1c3-1772595932337\",\"_type\":\"illustration\",\"alt\":\"abercrombie kent Across the Sout
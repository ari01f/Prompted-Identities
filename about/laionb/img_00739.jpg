<script id="wix-first-paint">
    if (window.ResizeObserver &&
        (!window.PerformanceObserver || !PerformanceObserver.supportedEntryTypes || PerformanceObserver.supportedEntryTypes.indexOf('paint') === -1)) {
        new ResizeObserver(function (entries, observer) {
            entries.some(function (entry) {
                var contentRect = entry.contentRect;
                if (contentRect.width > 0 && contentRect.height > 0) {
                    requestAnimationFrame(function (now) {
                        window.wixFirstPaint = now;
                        dispatchEvent(new CustomEvent('wixFirstPaint'));
                    });
                    observer.disconnect();
                    return true;
                }
            });
        }).observe(document.body);
    }
</script>


<script id="scroll-bar-width-calculation">
    const div = document.createElement('div')
    div.style.overflowY = 'scroll'
    div.style.width = '50px'
    div.style.height = '50px'
    div.style.visibility = 'hidden'
    document.body.appendChild(div)
    const scrollbarWidth= div.offsetWidth - div.clientWidth
    document.body.removeChild(div)
    if(scrollbarWidth > 0){
        document.body.style.setProperty('--scrollbar-width', `${scrollbarWidth}px`)
    }
</script>





    <style id=wix-custom-css>/* Users Custom CSS code */
 #SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-faq.wixui-section * {
  --wix-ui-tpa-accordion-divider-color: #000000 !important;
  --wix-ui-tpa-accordion-divider-width: 2px !important;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-faq.wixui-section *[viewbox="0 0 24 24"] {
  stroke: #000000;
  stroke-width: 3px;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope *[alt="Rewards-Icons.png"] {
  height: auto;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope *[style="font-style:italic"] {
  font-style: normal !important;
  font-size: 18px;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-dropdown__icon {
  width: 10px;
} 

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-lightbox__close-button {
  --stroke-width: 3px;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-square {
  aspect-ratio: 1;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope *[data-hook="inline-error-message"] {
  display: none;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-top {
  z-index: 100;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope .wixui-all .wixui-button__icon {
    transform: rotateX(180deg);
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope #wixui-comp-miidhw8i .wixui-comp-miidhw8i-container{
  max-width: 100% !important;
  margin: 0 !important;
}

#SITE_CONTAINER #main_MF#main_MF .css-editing-scope #wixui-ActiveRewardSpinner{
  display: none;
}
/* Allow scroll INSIDE Wix Studio popup */
#SITE_CONTAINER #main_MF#main_MF .css-editing-scope #wixui-POPUPS_ROOT .wixui-wixui-popup__content,
#SITE_CONTAINER #main_MF#main_MF .css-editing-scope #wixui-POPUPS_ROOT [data-testid="responsive-container-overflow"],
#SITE_CONTAINER #main_MF#main_MF .css-editing-scope #wixui-POPUPS_ROOT [data-testid="responsive-container"] {
  overflow-y: auto !important;
  max-height: 100vh !important;
}

/* Prevent background scroll */
#SITE_CONTAINER #main_MF#main_MF .css-editing-scope body.wixui-wix-popup-open {
  overflow: hidden !important;
}</style>



